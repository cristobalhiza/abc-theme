{% extends "base.twig" %}

{% block content %}
<main class="relative pt-20 overflow-hidden">
    {# SVG Decorativo Central #}
    <div aria-hidden="true" class="absolute inset-x-0 top-0 pointer-events-none z-0" 
         x-data="{ pathRevealed: false }" 
         x-init="setTimeout(() => pathRevealed = true, 150)">
        
        <div class="w-full overflow-hidden transition-all duration-[2000ms] ease-out"
             :style="pathRevealed ? 'max-height: 940px;' : 'max-height: 0px;'">
            
            <div class="h-[940px] w-full">
                <svg class="w-full h-full opacity-15" preserveAspectRatio="none" viewBox="0 0 1440 3000">
                    <path d="M720 0 C720 400 100 600 100 1000 S1340 1400 1340 2000 S720 2400 720 3000" fill="none" stroke="currentColor" stroke-width="40" class="text-primary"></path>
                    <path d="M720 0 C720 400 100 600 100 1000 S1340 1400 1340 2000 S720 2400 720 3000" fill="none" stroke="white" stroke-dasharray="30,30" stroke-width="2"></path>
                </svg>
            </div>
        </div>
    </div>

    {# ─── Hero Empresas ─── #}
    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-24">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
            <div>
                <h1 class="font-display text-4xl sm:text-5xl md:text-7xl font-bold text-text-main leading-tight tracking-tight mb-4 md:mb-8">
                    Para <span class="text-primary italic">Empresas</span>
                </h1>
                <p class="text-base sm:text-lg text-secondary-text leading-relaxed font-medium mb-6">
                    Somos una escuela acreditada y OTEC autorizada para trabajar con franquicia SENCE, especializada en capacitación de Licencias Profesionales A2 y A4 para trabajadores y empresas.
                </p>
                <p class="text-base sm:text-lg text-secondary-text leading-relaxed font-medium mb-8">
                    Apoyamos a organizaciones públicas y privadas con programas en modalidad presencial y e-learning, adaptados a sus tiempos operativos.                 Revisa nuestros <span x-data><a href="#" @click.prevent="$dispatch('open-convenios-modal')" class="text-primary font-medium underline hover:text-blue-800">convenios vigentes aquí</a></span>.
                </p>
            </div>
            <div class="relative group">
                <div class="absolute -inset-4 bg-primary/10 rounded-[32px] blur-xl transition duration-500 group-hover:bg-primary/20"></div>
                <div class="relative rounded-2xl md:rounded-[32px] overflow-hidden shadow-float h-full">
                    {# En fallback usa la imagen de recepción por si no existe convenios.webp #}
                    <img alt="Empresas y Convenios" class="w-full h-full object-cover transition-transform duration-700 hover:scale-105 aspect-auto" src="{{ theme.link }}/assets/images/convenios.webp" onerror="this.src='{{ theme.link }}/assets/images/abcconduccion-escuela-conductores-recepcion.webp'"/>
                </div>
            </div>
        </div>
    </section>

    {# ─── Cursos con Sence (Franquicia) - Layout Presentación ─── #}
    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-10 md:py-18 space-y-12 md:space-y-16">
        
        <div class="flex flex-col items-center mb-6">
            <span class="bg-blue-50 text-blue-600 font-bold uppercase tracking-widest text-xs px-4 py-1.5 rounded-full mb-3 md:mb-4">Beneficios para empresas</span>
            <h2 class="font-display font-bold text-3xl md:text-5xl text-center text-slate-900">Franquicia Tributaria SENCE</h2>
            <p class="mt-4 text-center text-secondary-text max-w-2xl font-medium">Contamos con programas autorizados por SENCE que permiten a las empresas utilizar la franquicia tributaria para capacitar a sus equipos con los más altos estándares.</p>
        </div>

        {# Contenedor del Slider #}
        <div x-data="{ 
                activeSlide: 0, 
                slides: 3,
                interval: null,
                startAutoPlay() {
                    this.interval = setInterval(() => {
                        this.activeSlide = this.activeSlide < this.slides - 1 ? this.activeSlide + 1 : 0;
                    }, 6000);
                },
                stopAutoPlay() {
                    if (this.interval) clearInterval(this.interval);
                },
                init() {
                    this.startAutoPlay();
                }
            }" 
            @mouseenter="stopAutoPlay()" 
            @mouseleave="startAutoPlay()"
            class="relative w-full max-w-[100vw]">
            {# Wrapper con overflow hidden #}
            <div class="overflow-hidden rounded-2xl md:rounded-3xl shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] border border-gray-200">
                <div class="flex transition-transform duration-500 ease-in-out" :style="`transform: translateX(-${activeSlide * 100}%)`">
                    
                    {# Slide 1: Curso B #}
                    <div class="w-full flex-shrink-0 flex flex-col xl:flex-row bg-[#f8fafc]">
                        {# Left Dark Pane #}
                        <div class="w-full xl:w-1/2 bg-[#0B1524] text-white p-6 md:p-8 lg:p-10 flex flex-col justify-center">
                            <div class="flex items-center gap-2 mb-4">
                                <img src="{{ theme.link }}/assets/logos/ABC-logo-nobg.webp" alt="ABC Logo" class="h-6 md:h-8 w-auto opacity-90 drop-shadow-md brightness-0 invert">
                                <span class="text-[0.6rem] md:text-xs font-bold uppercase tracking-[0.1em] md:tracking-[0.2em] text-[#6b9ccb]">ABC Escuela de Conductores</span>
                            </div>
                            <h3 class="font-display text-3xl lg:text-4xl font-bold mb-4 leading-tight tracking-tight">Licencia <span class="text-blue-400">Clase B</span><br>para Empresas</h3>
                            <p class="text-white/80 text-sm md:text-base mb-6 leading-relaxed max-w-xl">
                                Capacitación en <strong class="text-white font-semibold">modalidad presencial y e-learning</strong>, ideal para la formación inicial o colaboradores que requieren obtener su primera licencia para conducir.
                            </p>
                            <div class="space-y-3 mb-8">
                                <div class="flex items-center gap-3">
                                    <svg class="w-4 h-4 text-white shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                    <span class="text-white/90 font-medium text-sm md:text-base">Franquicia tributaria SENCE</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <svg class="w-4 h-4 text-white shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                    <span class="text-white/90 font-medium text-sm md:text-base">Programas adaptados a turnos operativos</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <svg class="w-4 h-4 text-white shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                    <span class="text-white/90 font-medium text-sm md:text-base">Instructores acreditados</span>
                                </div>
                                <div class="flex items-center gap-3">
