            {# Controles: Flechas Laterales #}
            <button @click="activeSlide = activeSlide > 0 ? activeSlide - 1 : slides - 1" class="absolute top-1/2 -left-3 md:-left-6 p-2 rounded-full bg-white shadow-lg border border-gray-100 text-primary hover:bg-primary hover:text-white transition-colors transform -translate-y-1/2 z-10 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center pointer-events-auto">
                <svg fill="none" class="w-5 h-5 md:w-6 md:h-6" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button @click="activeSlide = activeSlide < slides - 1 ? activeSlide + 1 : 0" class="absolute top-1/2 -right-3 md:-right-6 p-2 rounded-full bg-white shadow-lg border border-gray-100 text-primary hover:bg-primary hover:text-white transition-colors transform -translate-y-1/2 z-10 w-10 h-10 md:w-12 md:h-12 flex items-center justify-center pointer-events-auto">
