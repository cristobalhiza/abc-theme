{% extends "base.twig" %}

{% block content %}
<main class="relative pt-20 overflow-hidden">
    {# SVG Decorativo Central #}
    <div aria-hidden="true" class="absolute inset-x-0 top-0 pointer-events-none z-0" 
         x-data="{ pathRevealed: false }" 
         x-init="setTimeout(() => pathRevealed = true, 150)">
        
        <div class="w-full overflow-hidden transition-all duration-[2000ms] ease-out"
             :style="pathRevealed ? 'max-height: 940px;' : 'max-height: 0px;'">
            
            <div class="h-[940px] w-full">
                <svg class="w-full h-full opacity-15" preserveAspectRatio="none" viewBox="0 0 1440 3000">
                    <path d="M720 0 C720 400 100 600 100 1000 S1340 1400 1340 2000 S720 2400 720 3000" fill="none" stroke="currentColor" stroke-width="40" class="text-primary"></path>
                    <path d="M720 0 C720 400 100 600 100 1000 S1340 1400 1340 2000 S720 2400 720 3000" fill="none" stroke="white" stroke-dasharray="30,30" stroke-width="2"></path>
                </svg>
            </div>
        </div>
    </div>

    {# ─── Hero Empresas ─── #}
    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-12 md:py-24">
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
            <div>
                <h1 class="font-display text-4xl sm:text-5xl md:text-7xl font-bold text-text-main leading-tight tracking-tight mb-4 md:mb-8">
                    Para <span class="text-primary italic">Empresas</span>
                </h1>
                <p class="text-base sm:text-lg text-secondary-text leading-relaxed font-medium mb-6">
                    Somos una escuela acreditada y OTEC autorizada para trabajar con franquicia SENCE, especializada en capacitación de Licencias Profesionales A2 y A4 para trabajadores y empresas.
                </p>
                <p class="text-base sm:text-lg text-secondary-text leading-relaxed font-medium mb-8">
                    Apoyamos a organizaciones públicas y privadas con programas en modalidad presencial y e-learning, adaptados a sus tiempos operativos.
                </p>
            </div>
            <div class="relative group">
                <div class="absolute -inset-4 bg-primary/10 rounded-[32px] blur-xl transition duration-500 group-hover:bg-primary/20"></div>
                <div class="relative rounded-2xl md:rounded-[32px] overflow-hidden shadow-float h-full">
                    {# En fallback usa la imagen de recepción por si no existe convenios.webp #}
                    <img alt="Empresas y Convenios" class="w-full h-full object-cover transition-transform duration-700 hover:scale-105 aspect-auto" src="{{ theme.link }}/assets/images/convenios.webp" onerror="this.src='{{ theme.link }}/assets/images/abcconduccion-escuela-conductores-recepcion.webp'"/>
                </div>
            </div>
        </div>
    </section>

    {# ─── Cursos con Sence (Franquicia) ─── #}
    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-10 md:py-18">
        <div class="flex flex-col items-center mb-10 md:mb-16">
            <span class="bg-blue-50 text-blue-600 font-bold uppercase tracking-widest text-xs px-4 py-1.5 rounded-full mb-3 md:mb-4">Beneficios para empresas</span>
            <h2 class="font-display font-bold text-3xl md:text-5xl text-center text-slate-900">Franquicia Tributaria SENCE</h2>
            <p class="mt-4 text-center text-secondary-text max-w-2xl font-medium">Contamos con programas autorizados por SENCE que permiten a las empresas utilizar la franquicia tributaria para capacitar a sus equipos con los más altos estándares.</p>
        </div>
        
        <div class="grid lg:grid-cols-2 gap-6 md:gap-10">
            {# Curso B #}
            <div class="bg-white p-6 sm:p-8 md:p-10 rounded-2xl md:rounded-4xl shadow-float border border-primary/20 flex flex-col h-full relative overflow-hidden group hover:border-primary/50 transition-colors">
                <div class="absolute right-0 top-0 w-32 h-32 bg-primary/5 rounded-bl-full -mr-16 -mt-16 transition-transform group-hover:scale-110"></div>
                
                <h3 class="font-display font-bold text-3xl text-text-main mb-2">Clase B</h3>
                <p class="text-sm font-bold text-muted uppercase tracking-widest mb-6">Presencial y E-learning Sincrónico</p>
                
                <p class="text-secondary-text mb-8 leading-relaxed">
                    Ideal para la formación inicial o colaboradores que requieren obtener su primera licencia para conducir vehículos ligeros. Programa completo teórico y práctico.
                </p>
                
                <div class="mt-auto transform transition-transform group-hover:translate-x-1">
                    <span class="inline-flex items-center gap-2 text-primary font-bold bg-primary/10 px-4 py-2 rounded-xl">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Código SENCE Activo
                    </span>
                </div>
            </div>
            
            {# Curso A2/A4 #}
            <div class="bg-white p-6 sm:p-8 md:p-10 rounded-2xl md:rounded-4xl shadow-float border border-accent/20 flex flex-col h-full relative overflow-hidden group hover:border-accent/50 transition-colors">
                <div class="absolute right-0 top-0 w-32 h-32 bg-accent/5 rounded-bl-full -mr-16 -mt-16 transition-transform group-hover:scale-110"></div>

                <h3 class="font-display font-bold text-3xl text-text-main mb-2">Licencias Profesionales A2 y A4</h3>
                <p class="text-sm font-bold text-muted uppercase tracking-widest mb-6">Presencial y E-learning Sincrónico</p>
                
                <p class="text-secondary-text mb-8 leading-relaxed">
                    Capacitación especializada en transporte de pasajeros (A2) y transporte de carga (A4). Programas enfocados en la seguridad vial corporativa y conducción profesional.
                </p>
                
                <div class="mt-auto transform transition-transform group-hover:translate-x-1">
                    <span class="inline-flex items-center gap-2 text-accent font-bold bg-accent/10 px-4 py-2 rounded-xl">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Código SENCE Activo
                    </span>
                </div>
            </div>
        </div>
    </section>

    {# ─── Call to Action WhatsApp ─── #}
    <section x-data="ctaZoom()" x-ref="ctaSection" class="relative z-10 w-full py-12 md:py-24">
        <div x-ref="ctaCard"
             class="bg-[#0072b1] relative overflow-hidden shadow-2xl text-center will-change-transform origin-center mx-auto"
             :style="`transform: scale(${scale}); border-radius: ${radius}px; max-width: ${maxW}%;`">

            <div class="absolute inset-0 opacity-10 pointer-events-none">
                <svg fill="none" height="100%" width="100%" xmlns="http://www.w3.org/2000/svg">
                    <pattern height="40" id="grid-emp" patternUnits="userSpaceOnUse" width="40">
                        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1"></path>
                    </pattern>
                    <rect fill="url(#grid-emp)" height="100%" width="100%"></rect>
                </svg>
            </div>

            <div class="p-8 sm:p-10 md:p-16 lg:p-20 flex flex-col items-center justify-center relative z-10" :style="`opacity: ${contentOpacity}`">
                <div class="w-16 h-16 bg-white/20 rounded-2xl backdrop-blur-sm flex items-center justify-center mb-6 shadow-inner">
                    <svg class="w-8 h-8 text-white drop-shadow-[0_2px_4px_rgba(0,0,0,0.1)]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 21h18"></path>
                        <path d="M5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16"></path>
                        <path d="M9 7h6"></path>
                        <path d="M9 11h6"></path>
                        <path d="M9 15h6"></path>
                        <path d="M12 21v-4"></path>
                    </svg>
                </div>
                
                <h2 class="font-display font-bold text-3xl sm:text-4xl md:text-5xl text-white mb-6">Eleva el nivel de tu equipo</h2>
                <p class="text-white/90 text-base sm:text-xl max-w-2xl mx-auto mb-10 font-medium tracking-wide">
                    Si tu empresa necesita capacitar conductores o formar nuevos colaboradores, escríbenos y te asesoramos con una propuesta a medida.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center w-full sm:w-auto">
                    <a href="https://wa.me/56912345678?text=Hola,%20me%20comunico%20desde%20el%20sitio%20web.%20Quisiera%20asesoría%20sobre%20cursos%20para%20empresas%20con%20franquicia%20SENCE." target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-[#25D366] text-white px-8 h-14 rounded-xl font-bold hover:brightness-110 transition-all shadow-xl shadow-[#25D366]/30 uppercase tracking-widest gap-3 text-base group">
                        <svg class="w-6 h-6 transition-transform group-hover:scale-110" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                        Háblanos por WhatsApp
                    </a>
                </div>
            </div>
        </div>
    </section>

    <script>
    document.addEventListener('alpine:init', () => {
        if(!Alpine.store('ctaZoomDefined')) {
            Alpine.store('ctaZoomDefined', true);
            Alpine.data('ctaZoom', () => ({
                scale: 0.55,
                radius: 48,
                maxW: 60,
                contentOpacity: 0,
                ticking: false, 
                init() {
                    this.updateContext = this.updateContext.bind(this);
                    this.handleScroll = this.handleScroll.bind(this);
                    window.addEventListener('scroll', this.handleScroll, { passive: true });
                    this.updateContext();
                },
                destroy() {
                    window.removeEventListener('scroll', this.handleScroll);
                },
                handleScroll() {
                    if (!this.ticking) {
                        requestAnimationFrame(() => {
                            this.updateContext();
                            this.ticking = false;
                        });
                        this.ticking = true;
                    }
                },
                updateContext() {
                    const section = this.$refs.ctaSection;
                    if (!section) return;
                    const rect = section.getBoundingClientRect();
                    const vh = window.innerHeight;
                    const rawProgress = 1 - (rect.top / vh);
                    const progress = Math.min(1, Math.max(0, rawProgress));
                    const eased = 1 - Math.pow(1 - progress, 4);
                    this.scale      = 0.55 + (eased * 0.45);
                    this.radius     = 48 - (eased * 48);
                    // Adjust width for desktop screens slightly better
                    this.maxW       = window.innerWidth > 768 ? 60 + (eased * 40) : 90 + (eased * 10);
                    this.contentOpacity = eased;
                }
            }));
        }
    });
    </script>
</main>
{% endblock %}
