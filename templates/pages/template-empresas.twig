                                    <span class="text-white/90 font-medium text-sm md:text-base">En dependencias de la empresa o sede ABC</span>
                                </div>
                            </div>
                            <button @click.prevent="$dispatch('open-contact-modal', { course: 'Clase A2' })" class="bg-primary hover:bg-white hover:text-primary border-2 border-primary text-white font-bold py-2.5 px-5 rounded-lg transition-colors w-max uppercase text-xs md:text-sm tracking-wide">
                                Solicitar propuesta comercial
                            </button>
                        </div>

                        {# Right Light Pane #}
                        <div class="w-full xl:w-1/2 p-5 md:p-8 flex flex-col justify-center gap-4 relative">
                            {# Top Box #}
                            <div class="bg-white rounded-2xl md:rounded-3xl p-6 md:p-8 shadow-float border border-gray-100 flex-1 relative z-10 flex flex-col justify-center">
                                <h4 class="text-lg md:text-xl font-bold text-[#0B1524] mb-5">Beneficios para tu empresa</h4>
                                <ul class="space-y-3 text-[#4a5568] text-sm font-medium">
                                    <li class="flex items-start gap-3">
                                        <span class="text-[#0B1524] font-black mt-0.5">•</span>
                                        <span>Optimización de costos vía <strong class="text-[#0B1524] font-bold">franquicia tributaria</strong></span>
                                    </li>
                                    <li class="flex items-start gap-3">
                                        <span class="text-[#0B1524] font-black mt-0.5">•</span>
                                        <span>Formación alineada a normativa vigente</span>
                                    </li>
                                    <li class="flex items-start gap-3">
                                        <span class="text-[#0B1524] font-black mt-0.5">•</span>
                                        <span>Flexibilidad horaria para continuidad operacional</span>
                                    </li>
                                    <li class="flex items-start gap-3">
                                        <span class="text-[#0B1524] font-black mt-0.5">•</span>
                                        <span>Mayor empleabilidad y desarrollo interno</span>
                                    </li>
                                    <li class="flex items-start gap-3">
                                        <span class="text-[#0B1524] font-black mt-0.5">•</span>
                                        <span>Apoyo administrativo en gestión SENCE / OTIC</span>
                                    </li>
                                </ul>
                            </div>
                            
                            {# Bottom Box #}
                            <div class="bg-[#f1f5f9] rounded-2xl p-5 text-sm md:text-sm text-[#4a5568] font-medium leading-relaxed border border-gray-200/60 relative z-10">
                                Ideal para empresas con flotas de transporte, logística de pasajeros, transfers y servicios turísticos.
                            </div>
                        </div>
                    </div>

                    {# Slide 3: Curso A4 #}
                    <div class="w-full flex-shrink-0 flex flex-col xl:flex-row bg-[#f8fafc]">
                        {# Left Dark Pane #}
                        <div class="w-full xl:w-1/2 bg-[#0B1524] text-white p-6 md:p-8 lg:p-10 flex flex-col justify-center">
                            <div class="flex items-center gap-2 mb-4">
                                <img src="{{ theme.link }}/assets/logos/ABC-logo-nobg.webp" alt="ABC Logo" class="h-6 md:h-8 w-auto opacity-90 drop-shadow-md brightness-0 invert">
                                <span class="text-[0.6rem] md:text-xs font-bold uppercase tracking-[0.1em] md:tracking-[0.2em] text-[#6b9ccb]">ABC Escuela de Conductores</span>
                            </div>
                            <h3 class="font-display text-3xl lg:text-4xl font-bold mb-4 leading-tight tracking-tight">Licencia Profesional<br><span class="text-accent">A4</span> para Empresas</h3>
