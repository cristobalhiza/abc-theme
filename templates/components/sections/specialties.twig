{# Ubicación: templates/components/specialties.twig #}

{% set specialties = [
    {
        title: 'Material Didáctico',
        desc: 'Guías de estudio actualizadas y manuales diseñados para un rápido aprendizaje teórico.',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>',
        bg: 'bg-white', text: 'text-text-main', iconBg: 'bg-primary/10', iconColor: 'text-primary'
    },
    {
        title: 'Ensayos Psicotécnicos',
        desc: 'Laboratorio equipado con máquinas similares a las del examen municipal.',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>',
        bg: 'bg-white', text: 'text-text-main', iconBg: 'bg-accent/10', iconColor: 'text-accent'
    },
    {
        title: 'Exámenes de Prueba',
        desc: 'Simuladores de evaluación para garantizar tu seguridad al momento de rendir.',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
        bg: 'bg-white', text: 'text-text-main', iconBg: 'bg-green-100', iconColor: 'text-green-600'
    }
] %}

<section id="specialties" class="py-12 relative bg-background overflow-hidden">
    
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        
        {# Cabecera #}
        <div class="text-center max-w-3xl mx-auto mb-16" x-data="{ shown: false }" x-intersect.once="shown = true">
            <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-text-main font-display mb-6 transition-all duration-700 delay-100 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
                Preparación Integral para tu <span class="text-primary">Éxito en Ruta</span>
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6" x-data="{ shown: false }" x-intersect.once.margin.-100px="shown = true">
            
            {# Fila Superior: Las 3 Tarjetas de Especialidades #}
            {% for item in specialties %}
            <div class="{{ item.bg }} rounded-[24px] p-6 shadow-sm border border-gray-50 flex flex-col items-start transition-all duration-700 hover:-translate-y-1 hover:shadow-md">
                <div class="w-12 h-12 rounded-xl {{ item.iconBg }} {{ item.iconColor }} flex items-center justify-center mb-4">
                    <div class="w-6 h-6">{{ item.icon|raw }}</div>
                </div>
                <h3 class="text-lg font-bold font-display {{ item.text }} mb-2">{{ item.title }}</h3>
                <p class="text-muted text-sm leading-relaxed">{{ item.desc }}</p>
            </div>
            {% endfor %}

            {# Fila Superior: Tarjeta Flota #}
            <div class="bg-primary rounded-[24px] p-6 shadow-xl shadow-primary/20 relative overflow-hidden flex flex-col items-start transition-all duration-700 hover:-translate-y-1 hover:shadow-2xl">
                <div class="w-12 h-12 rounded-xl bg-white/20 text-white flex items-center justify-center mb-4 relative z-10">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
                </div>
                <h3 class="text-lg font-bold font-display text-white mb-2 relative z-10">Flota Doble Comando</h3>
                <p class="text-white/90 text-sm leading-relaxed relative z-10">Vehículos modernos equipados para garantizar tu seguridad en todo momento.</p>
                <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>
            </div>

            {# Fila Inferior: Tarjeta Convenios #}
            <div @click="$dispatch('open-convenios-modal')" class="col-span-1 md:col-span-2 lg:col-span-4 bg-gradient-to-br from-blue-50 to-white rounded-[24px] p-8 shadow-sm border border-blue-100 flex flex-col md:flex-row items-center justify-between gap-6 cursor-pointer transition-all duration-300 hover:shadow-md hover:-translate-y-1 group mt-2">
                <div>
                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-blue-100 rounded-full text-blue-800 text-xs font-bold uppercase tracking-wider mb-4">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        Nuevos Convenios
                    </div>
                    <h3 class="text-2xl font-bold font-display text-text-main mb-2">¿Perteneces a nuestras instituciones en convenio?</h3>
                    <p class="text-muted text-sm">Alumnos, funcionarios y familiares obtienen un <strong class="text-primary">20% de descuento</strong> en todos los cursos.</p>
                </div>
                <div class="w-12 h-12 md:w-16 md:h-16 rounded-full bg-primary text-white flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
            </div>

        </div>
    </div>
</section>