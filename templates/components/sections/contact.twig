{# Ubicación: templates/components/contact.twig #}

<section id="contacto" class="relative py-24 flex items-center justify-center min-h-[90vh] overflow-hidden">
    
    {# Fondo del Mapa (Asegúrate de cambiar la ruta de la imagen) #}
    <div class="absolute inset-0 z-0">
        <img src="{{ theme.link }}/assets/images/map-bg.png" alt="Mapa de ubicación" class="w-full h-full object-cover opacity-20">
        <div class="absolute inset-0 bg-linear-to-b from-background-light/80 via-transparent to-background-light/90 mix-blend-overlay"></div>
    </div>

    {# Final de la Ruta Continua #}
    <div class="absolute left-1/2 top-0 h-32 w-1 -translate-x-1/2 bg-primary z-10"></div>
    
    {# Pin de Ubicación (Destino) #}
    <div class="absolute left-1/2 top-32 -translate-x-1/2 -translate-y-1/2 z-20">
        <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-xl ring-8 ring-primary/20 border-2 border-primary">
            <svg class="w-6 h-6 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
    </div>

    <div class="relative z-20 w-full max-w-4xl px-6 flex flex-col items-center mt-16">
        
        <div class="text-center mb-10">
            <h2 class="text-4xl md:text-5xl font-bold tracking-tight font-display text-text-main mb-4">Tu destino está aquí.</h2>
            <p class="text-[#666] text-base font-medium max-w-md mx-auto">Déjanos tus datos para iniciar tu proceso de matrícula en ABC Escuela de Conductores.</p>
        </div>

        {# Tarjeta del Formulario controlada por Alpine.js #}
        <div class="w-full max-w-md bg-white rounded-4xl shadow-float p-8 md:p-10 border border-gray-100"
             x-data="contactForm()"
             @submit.prevent="submitForm">
            
            {# Estado de Éxito #}
            <div x-show="isSuccess" x-cloak class="flex flex-col items-center text-center py-8" x-transition.opacity>
                <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <h3 class="text-2xl font-bold text-text-main font-display mb-2">¡Mensaje Enviado!</h3>
                <p class="text-muted font-medium">Te contactaremos a la brevedad para afinar los detalles de tu solicitud.</p>
                <button @click="resetForm" type="button" class="mt-6 text-primary font-bold text-sm uppercase tracking-wide hover:underline">Enviar otro mensaje</button>
            </div>

            {# Formulario #}
            <form x-show="!isSuccess" x-transition.opacity class="space-y-5">
                
                {# Mensaje de error general del servidor #}
                <div x-show="serverError" x-cloak class="p-4 bg-red-50 text-red-600 text-sm font-medium rounded-xl border border-red-100" x-text="serverError"></div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-text-main ml-1">Nombre Completo</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-muted">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        </span>
                        <input type="text" x-model="formData.name" placeholder="Ej. Juan Pérez" required
                               class="w-full h-14 pl-12 pr-4 rounded-2xl bg-background-light border-transparent focus:bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-text-main">
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-text-main ml-1">Correo Electrónico</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-muted">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        </span>
                        <input type="email" x-model="formData.email" placeholder="juan@ejemplo.com" required
                               class="w-full h-14 pl-12 pr-4 rounded-2xl bg-background-light border-transparent focus:bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-text-main">
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-text-main ml-1">Teléfono</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2" :class="errors.phone ? 'text-red-500' : 'text-muted'">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        </span>
                        <input type="tel" x-model="formData.phone" @input="validatePhone" placeholder="+56 9 1234 5678" required
                               class="w-full h-14 pl-12 pr-10 rounded-2xl transition-all text-text-main"
                               :class="errors.phone ? 'bg-red-50 border-red-300 focus:ring-red-500/20 focus:border-red-500 text-red-900' : 'bg-background-light border-transparent focus:bg-white focus:border-primary focus:ring-2 focus:ring-primary/20'">
                        
                        {# Icono de error condicional según tu mockup #}
                        <span x-show="errors.phone" class="absolute right-4 top-1/2 -translate-y-1/2 text-red-500">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                        </span>
                    </div>
                    <p x-show="errors.phone" class="text-xs text-red-500 ml-1 mt-1">Por favor, ingresa un número válido.</p>
                </div>

                <div class="space-y-1.5" x-data="{ open: false }" @click.outside="open = false">
                    <label class="text-xs font-bold text-text-main ml-1">Cursos de Interés</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 z-10" :class="errors.course ? 'text-red-500' : 'text-muted'">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                        </span>
                        
                        <div @click="open = !open" tabindex="0" @keydown.enter="open = !open"
                             class="w-full min-h-[56px] pl-12 pr-10 py-2 rounded-2xl border transition-all cursor-pointer flex flex-wrap items-center gap-2"
                             :class="errors.course ? 'bg-red-50 border-red-300 ring-2 ring-red-500/20' : (open ? 'bg-white border-primary ring-2 ring-primary/20' : 'bg-background-light border-transparent')">
                             
                            <template x-if="formData.course.length === 0">
                                <span class="text-text-main select-none mt-0.5" :class="errors.course ? 'text-red-900' : 'text-muted'">Selecciona cursos...</span>
                            </template>
                            
                            <template x-for="val in formData.course" :key="val">
                                <span class="inline-flex items-center gap-1 bg-primary text-white text-xs font-bold px-2.5 py-1.5 rounded-lg z-10">
                                    <span x-text="getCourseLabel(val)"></span>
                                    <button type="button" @click.stop="formData.course = formData.course.filter(c => c !== val); if(formData.course.length === 0) errors.course = true;" class="hover:text-red-200 transition-colors focus:outline-none">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                                    </button>
                                </span>
                            </template>
                        </div>
                        
                        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-muted pointer-events-none transition-transform duration-200"
                              :class="open ? 'rotate-180' : ''">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </span>
                        
                        <div x-show="open" 
                             x-transition:enter="transition ease-out duration-150"
                             x-transition:enter-start="opacity-0 -translate-y-2"
                             x-transition:enter-end="opacity-100 translate-y-0"
                             x-transition:leave="transition ease-in duration-100"
                             x-transition:leave-start="opacity-100 translate-y-0"
                             x-transition:leave-end="opacity-0 -translate-y-2"
                             class="absolute z-[100] top-[calc(100%+8px)] left-0 w-full bg-white rounded-2xl shadow-xl border border-gray-100 py-2"
                             x-cloak>
                            <template x-for="option in courseOptions" :key="option.value">
                                <label class="flex items-center gap-3 px-4 py-3 hover:bg-background-light cursor-pointer transition-colors group">
                                    <div class="relative flex items-center justify-center w-5 h-5 border-2 rounded transition-colors"
                                         :class="formData.course.includes(option.value) ? 'border-primary bg-primary' : 'border-gray-300 group-hover:border-primary'">
                                        <svg x-show="formData.course.includes(option.value)" class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                    </div>
                                    <input type="checkbox" :value="option.value" x-model="formData.course" @change="errors.course = formData.course.length === 0" class="sr-only">
                                    <span class="text-sm font-medium transition-colors" 
                                          :class="option.comingSoon ? 'text-[#888] italic px-1' : 'text-text-main'" 
                                          x-text="option.label"></span>
                                </label>
                            </template>
                        </div>
                    </div>
                    <p x-show="errors.course" class="text-xs text-red-500 ml-1 mt-1" x-cloak>Por favor, selecciona al menos un curso.</p>
                </div>

                <label class="flex items-center gap-3 cursor-pointer group w-fit ml-1 mt-2">
                    <div class="relative flex items-center justify-center w-5 h-5 border-2 rounded transition-colors"
                         :class="formData.isCompany ? 'border-primary bg-primary' : 'border-gray-300 group-hover:border-primary'">
                         <svg x-show="formData.isCompany" x-cloak class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <input type="checkbox" x-model="formData.isCompany" class="sr-only">
                    <span class="text-sm font-bold text-text-main select-none">¿Eres empresa?</span>
                </label>

                {# Cloudflare Turnstile Widget #}
                <div class="mt-3">
                    <div x-ref="turnstileContainer"></div>
                    <p x-show="errors.turnstile" class="text-xs text-red-500 ml-1 mt-1" x-cloak>Por favor, completa la verificación de seguridad.</p>
                </div>

                <button type="submit" :disabled="isLoading || errors.phone || formData.course.length === 0 || !formData.turnstileToken" 
                        class="w-full h-14 mt-4 bg-primary text-white rounded-2xl font-bold font-display uppercase tracking-wide flex items-center justify-center gap-2 hover:brightness-110 shadow-lg shadow-primary/30 transition-all disabled:opacity-70 disabled:cursor-not-allowed group">
                    <span x-text="isLoading ? 'Enviando...' : 'Envíar mensaje'"></span>
                    <svg x-show="!isLoading" class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    
                    {# Spinner de carga #}
                    <svg x-show="isLoading" x-cloak class="w-5 h-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                </button>
            </form>
        </div>

        {# Información de contacto inferior (Rediseñada) #}
        <div class="mt-8 w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12 border-t border-gray-100 pt-8">
            
            {# Dirección #}
            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <div class="flex items-center gap-2 mb-2">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span class="text-[0.65rem] font-bold uppercase tracking-[0.1em] text-muted">Ubicación</span>
                </div>
                <a href="https://maps.app.goo.gl/Wxz6ic5KYoHDiBXF9" target="_blank" rel="noopener noreferrer" 
                   class="text-sm font-medium text-text-main hover:text-primary transition-colors leading-relaxed">
                    Av. Bellavista 0213, <br> Providencia, Región Metropolitana de Santiago, Chile.
                </a>
            </div>

            {# Email #}
            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <div class="flex items-center gap-2 mb-2">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    <span class="text-[0.65rem] font-medium uppercase tracking-[0.1em] text-muted">Escríbenos</span>
                </div>
                <a href="mailto:ventas@abcconduccion.cl" 
                   class="text-sm font-medium text-text-main hover:text-primary transition-colors">
                    ventas@abcconduccion.cl
                </a>
            </div>

            {# Teléfonos #}
            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <div class="flex items-center gap-2 mb-2">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    <span class="text-[0.65rem] font-medium uppercase tracking-[0.1em] text-muted">Llámanos</span>
                </div>
                <div class="flex flex-col gap-1 text-sm font-medium text-text-main">
                    <a href="tel:+56226381813" class="hover:text-primary transition-colors">(+56) 2 2638 1813</a>
                    <a href="tel:+56226382383" class="hover:text-primary transition-colors">(+56) 2 2638 2383</a>
                </div>
            </div>

            {# Horario #}
            <div class="flex flex-col items-center md:items-start text-center md:text-left">
                <div class="flex items-center gap-2 mb-2">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span class="text-[0.65rem] font-medium uppercase tracking-[0.1em] text-muted">Horario</span>
                </div>
                <div class="text-sm font-medium text-text-main leading-relaxed">
                    Lun - Vie <br>
                    <span class="text-primary">09:00 - 18:00 hrs</span>
                </div>
            </div>
        </div>

    </div>
</section>