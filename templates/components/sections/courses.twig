{# Ubicación: templates/components/courses.twig #}

<section id="courses" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
        
        {# Cabecera de la Sección #}
        <div class="flex flex-col gap-4 mb-16">
            <div class="flex items-center gap-2 text-primary">
                <span class="h-1 w-12 bg-primary rounded-full"></span>
                <span class="text-sm font-bold uppercase tracking-widest">Excelencia en Ruta</span>
            </div>
            <h2 class="text-5xl md:text-6xl font-bold tracking-tight text-text-main font-display">
                Nuestros Cursos de <span class="text-primary">Conducción</span>
            </h2>
            <p class="text-lg text-secondary-text max-w-2xl">
                Formación integral con un enfoque en seguridad vial. Clases teóricas modernas, horas prácticas intensivas y el mejor material didáctico. Revisa nuestros <span x-data><a href="#" @click.prevent="$dispatch('open-convenios-modal')" class="text-primary font-medium underline hover:text-blue-800">convenios vigentes aquí</a></span>.
            </p>
        </div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            {% for course in cursos %}
                
                {% set is_primary = loop.index == 2 %}
                {% set price = course.meta('_abc_precio_normal') ?: course.meta('_abc_precio_normal') %}

                <div class="group relative flex flex-col bg-background-light rounded-[24px] overflow-hidden shadow-float border transition-all duration-300 hover:-translate-y-2 hover:shadow-xl {{ is_primary ? 'border-primary ring-4 ring-primary/5' : 'border-transparent' }}">
                    
                    {# 1. ENLACE GLOBAL INVISIBLE QUE CUBRE TODA LA TARJETA #}
                    <a href="{{ course.link }}" class="absolute inset-0 z-10" aria-label="Ver detalles de {{ course.title }}"></a>

                    {# Imagen y Badge Superior #}
                    <div class="h-56 relative overflow-hidden bg-gray-200">
                        {% if course.thumbnail %}
                            <img src="{{ course.thumbnail.src }}" alt="{{ course.title }}" loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                        {% endif %}
                        
                        <div class="absolute top-4 left-4 px-4 py-1 rounded-full text-[0.625rem] font-bold uppercase tracking-widest shadow-md {{ is_primary ? 'bg-accent text-white' : 'bg-primary text-white' }}">
                            {{ is_primary ? 'Más Popular' : 'Certificado' }}
                        </div>
                    </div>

                    {# Contenido de la Tarjeta #}
                    <div class="p-8 flex flex-col flex-1 relative">
                        <div class="flex justify-between items-start mb-2 relative z-0">
                            {# Título transformado a h3 #}
                            <h3 class="text-2xl font-bold font-body text-text-main group-hover:text-primary transition-colors">{{ course.title }}</h3>
                            {% if price %}
                                <span class="text-primary font-bold text-lg font-body">${{ price|number_format(0, ',', '.') }}</span>
                            {% endif %}
                        </div>
                        
                        <p class="text-muted text-sm font-medium mb-8 leading-relaxed relative z-0">{{ course.excerpt({ words: 50, read_more: '' }) }}</p>
                        
                        <ul class="space-y-4 mb-8 relative z-0">
                            <li class="flex items-start gap-3">
                                <div class="bg-primary/10 rounded-full p-1 text-primary">
                                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                                </div>
                                <span class="text-sm font-semibold text-muted leading-tight">Clases teóricas presenciales y online</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <div class="bg-primary/10 rounded-full p-1 text-primary">
                                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                </div>
                                <span class="text-sm font-semibold text-muted leading-tight">Horas de práctica en ruta real</span>
                            </li>
                        </ul>

                        {# 2. BOTONES #}
                        <div class="mt-auto flex flex-col items-center gap-2 w-full relative z-20" x-data>
                            
                            <button type="button" @click.prevent="$dispatch('open-contact-modal', { course: '{{ course.title }}' })" class="w-full h-12 rounded-xl font-bold flex items-center justify-center gap-2 transition-all {{ is_primary ? 'bg-primary text-white hover:brightness-110 shadow-lg' : 'bg-white text-primary hover:bg-primary hover:text-white border border-primary/50' }}">
                                Inscribirme ahora
                                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </button>
                            
                            <span class="text-xs font-bold text-muted group-hover:text-primary transition-colors underline underline-offset-4 decoration-primary/30 group-hover:decoration-primary cursor-pointer pointer-events-none">
                                Ver detalles
                            </span>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-8">
            
            {# Tarjeta: Próximamente #}
            <div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded-[24px] p-6 md:p-8 flex flex-col justify-between gap-6 opacity-90 hover:opacity-100 transition-all duration-300 hover:border-primary/50 group h-full">
                
                <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 text-center sm:text-left">
                    {# Ícono estilo industrial/maquinaria #}
                    <div class="w-16 h-16 rounded-2xl bg-gray-200 flex items-center justify-center shrink-0 text-gray-500 group-hover:text-primary transition-colors">
                        <svg class="w-8 h-8" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"></path>
                        </svg>
                    </div>
                    
                    <div>
                        <div class="inline-block px-3 py-1 rounded-full text-[0.65rem] font-bold uppercase tracking-widest bg-gray-200 text-gray-600 mb-2">
                            Próximamente
                        </div>
                        <h3 class="text-xl md:text-2xl font-bold font-display text-text-main group-hover:text-primary transition-colors leading-tight">
                            Operador de Grúa Horquilla (Clase D)
                        </h3>
                        <p class="text-sm text-muted mt-2 leading-relaxed">
                            Estamos preparando un circuito de práctica especializado para maquinaria. Anótate en la lista de espera y obtén un descuento exclusivo de lanzamiento.
                        </p>
                    </div>
                </div>

                <div class="w-full shrink-0 flex justify-center sm:justify-start" x-data>
                    <button type="button" @click.prevent="$dispatch('open-contact-modal', { course: 'Clase D' })" class="w-full px-6 py-3 rounded-xl font-bold text-sm bg-white text-text-main border-2 border-gray-200 hover:border-primary hover:text-primary shadow-sm hover:shadow-md transition-all flex items-center justify-center gap-2">
                        Anotarme en la lista
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                    </button>
                </div>
                
            </div>

            {# Tarjeta: Promoción Especial A2 + A4 #}
            <div class="relative bg-gradient-to-r from-[#0d2a45] to-primary rounded-[24px] p-6 md:p-8 text-white shadow-2xl overflow-hidden shadow-primary/20 flex flex-col justify-between h-full text-center sm:text-left">
                {# Patrón Decorativo de Fondo #}
                <div class="absolute inset-0 opacity-10 road-line rotate-2 skew-x-12 scale-150"></div>
                <div class="absolute right-0 top-0 w-64 h-full bg-white/5 skew-x-12 translate-x-12"></div>
                
                <div class="relative z-10 flex flex-col gap-6 h-full">
                    <div class="flex-1">
                        <div class="inline-block px-3 py-1 rounded-full text-[0.65rem] font-bold uppercase tracking-widest bg-accent text-white mb-3 shadow-lg shadow-accent/20">
                            Promoción Especial Limitada
                        </div>
                        <h3 class="text-2xl md:text-3xl font-bold font-display mb-4 leading-tight">
                            Cursos de Conducción <span class="text-accent brightness-110 block mt-1">Clase A2 + A4</span>
                        </h3>
                        
                        <div class="flex flex-row items-center justify-center sm:justify-start gap-4 sm:gap-6 mt-1">
                            <div class="flex flex-col items-center sm:items-start text-white/70">
                                <span class="text-[0.65rem] font-bold uppercase tracking-[0.2em] mb-0.5">Valor Normal</span>
                                <span class="text-lg line-through decoration-red-500/70 font-semibold">$220.000</span>
                            </div>
                            <div class="w-px h-8 bg-white/20"></div>
                            <div class="flex flex-col items-center sm:items-start">
                                <span class="text-[0.65rem] font-bold uppercase tracking-[0.2em] text-accent mb-0.5">Valor Oferta</span>
                                <span class="text-3xl font-black font-display tracking-tight">$180.000</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="w-full flex-shrink-0 mt-2" x-data>
                        <button type="button" @click.prevent="$dispatch('open-contact-modal', { course: ['Clase A2', 'Clase A4'] })" class="w-full inline-flex h-12 px-6 bg-white text-primary rounded-xl font-bold text-sm uppercase tracking-wider items-center justify-center gap-2 hover:bg-background-light shadow-xl hover:shadow-2xl hover:shadow-white/20 transition-all duration-300 hover:-translate-y-1 group relative z-20">
                            Aprovechar Oferta
                            <div class="bg-primary/10 rounded-full p-1 group-hover:bg-primary group-hover:text-white transition-colors">
                                <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            </div>
                        </button>
                    </div>
                </div>
            </div>
            
        </div>

        <div class="mt-16 relative h-28 w-full overflow-hidden flex items-center justify-center">
<div class="absolute inset-0 opacity-10 road-line rotate-2 skew-x-12 scale-150"></div>
<div class="flex flex-col items-center z-10 text-center px-4">
    <p class="text-primary font-black text-lg uppercase tracking-[0.3em]">Tu futuro al volante comienza aquí</p>
    
    <div class="flex items-center gap-4 mt-2">
        <div class="h-0.5 w-20 bg-primary"></div>
        
<div class="flex items-center justify-center text-primary w-8 h-8">
    {{ source('assets/icons/minor_crash.svg') }}
</div>
        
        <div class="h-0.5 w-20 bg-primary"></div>
    </div>
</div>
    
</section>