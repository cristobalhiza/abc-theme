{# Ubicación: templates/components/navbar.twig #}
<nav x-data="{ isScrolled: false, isMobileMenuOpen: false }" 
     x-effect="document.body.style.overflow = isMobileMenuOpen ? 'hidden' : ''"
     @scroll.window="isScrolled = (window.pageYOffset > 20)"
     @close-mobile-menu.window="isMobileMenuOpen = false"
     :class="isMobileMenuOpen ? 'bg-transparent py-5' : (isScrolled ? 'bg-white/90 backdrop-blur-md shadow-sm py-3' : 'bg-transparent py-5')"
     class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
    
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
        
        {# Logo #}
        <a href="{{ site.url }}" class="flex items-center transition-transform hover:scale-105 relative z-[60]">
            <img src="{{ theme.link }}/assets/logos/ABC-logo-nobg.webp?v={{ "now"|date('U') }}" 
                 alt="Logo ABC Academia de Conducción" 
                 :class="isScrolled ? 'h-9 md:h-10' : 'h-11 md:h-14'"
                 class="w-auto transition-all duration-500 object-contain" />
        </a>
            
        {# Menú Desktop #}
        <div class="hidden md:flex items-center gap-6">
            <a href="{{ site.url }}" class="text-[0.8rem] font-bold uppercase tracking-widest text-text-main hover:text-primary transition-colors">Inicio</a>
            <a href="{{ site.url }}/nuestra-escuela" class="text-[0.8rem] font-bold uppercase tracking-widest text-text-main hover:text-primary transition-colors">Escuela</a>
            
            {# Dropdown de Cursos (Desktop) #}
            <div class="relative" x-data="{ dropdownOpen: false }" @mouseenter="dropdownOpen = true" @mouseleave="dropdownOpen = false">
                <a href="{{ site.url }}#courses" class="flex items-center gap-1 text-[0.8rem] font-bold uppercase tracking-widest text-text-main hover:text-primary transition-colors py-2">
                    Cursos
                    <svg class="w-4 h-4 transition-transform duration-200" :class="dropdownOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </a>
                
                {# Panel del Dropdown #}
                <div x-show="dropdownOpen" x-cloak
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0 translate-y-2"
                     x-transition:enter-end="opacity-100 translate-y-0"
                     x-transition:leave="transition ease-in duration-150"
                     x-transition:leave-start="opacity-100 translate-y-0"
                     x-transition:leave-end="opacity-0 translate-y-2"
                     class="absolute top-full left-1/2 -translate-x-1/2 mt-1 w-64 bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden py-2">
                    
                    <a href="{{ site.url }}/courses/licencia-clase-b" class="block px-5 py-3 hover:bg-background-light group transition-colors">
                        <span class="block text-sm font-bold text-text-main group-hover:text-primary">Licencia Clase B</span>
                        <span class="block text-xs text-muted mt-0.5">Para vehículos particulares</span>
                    </a>
                    <a href="{{ site.url }}/courses/profesional-a2" class="block px-5 py-3 hover:bg-background-light group transition-colors border-t border-gray-50">
                        <span class="block text-sm font-bold text-text-main group-hover:text-primary">Profesional A2</span>
                        <span class="block text-xs text-muted mt-0.5">Transporte de pasajeros</span>
                    </a>
                    <a href="{{ site.url }}/courses/profesional-a4" class="block px-5 py-3 hover:bg-background-light group transition-colors border-t border-gray-50">
                        <span class="block text-sm font-bold text-text-main group-hover:text-primary">Profesional A4</span>
                        <span class="block text-xs text-muted mt-0.5">Transporte de carga pesada</span>
                    </a>
                    <a href="{{ site.url }}/empresas" class="block px-5 py-3 hover:bg-background-light group transition-colors border-t border-gray-50">
                        <span class="block text-sm font-bold text-text-main group-hover:text-primary">Para empresas</span>
                        <span class="block text-xs text-muted mt-0.5">Convenios y SENCE</span>
                    </a>
                </div>
            </div>

            <a href="{{ site.url }}#contacto" class="text-[0.8rem] font-bold uppercase tracking-widest text-text-main hover:text-primary transition-colors">Contacto</a>
            <a href="https://practicatest.cl/escuela/abc-escuela-de-conductores-profesionales-en-providencia/Y5-Z?u=login" target="_blank" rel="nofollow noopener noreferrer" class="text-[0.8rem] font-bold uppercase tracking-widest text-text-main hover:text-primary transition-colors">PracticaTest</a>
            
            <div class="w-px h-6 bg-gray-200 mx-1"></div>

            <a href="https://abcconduccion.cl/aulavirtual" target="_blank" rel="noopener" class="flex items-center gap-2 px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-widest text-primary bg-primary/5 border border-primary/20 hover:bg-primary/10 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                Aula Virtual
            </a>
            <a href="https://www.webpay.cl/company/29034" target="_blank" rel="nofollow noopener noreferrer" class="flex items-center gap-2 px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest text-white bg-primary hover:brightness-110 shadow-lg shadow-primary/30 transition-all hover:-translate-y-0.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                Paga aquí
            </a>
        </div>

        {# Botón Menú Mobile #}
        <button class="md:hidden p-2 focus:outline-none relative z-[60] transition-colors duration-300"
                :class="isMobileMenuOpen ? 'text-white' : 'text-text-main'"
                @click="isMobileMenuOpen = !isMobileMenuOpen" aria-label="Abrir menú">
            <svg x-show="!isMobileMenuOpen" class="w-8 h-8" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="#0683C0" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg x-show="isMobileMenuOpen" x-cloak class="w-8 h-8" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>

    {# Overlay Full-Screen Mobile #}
    <template x-teleport="body">
        <div x-show="isMobileMenuOpen" x-cloak 
             x-transition:enter="transition ease-out duration-500"
             x-transition:enter-start="opacity-0 backdrop-blur-none"
             x-transition:enter-end="opacity-100 backdrop-blur-2xl"
             x-transition:leave="transition ease-in duration-300"
             x-transition:leave-start="opacity-100 backdrop-blur-2xl"
             x-transition:leave-end="opacity-0 backdrop-blur-none"
             class="fixed inset-0 z-50 bg-[#0d2a45]/95 md:hidden flex flex-col justify-center items-center overflow-y-auto"
             @click.self="isMobileMenuOpen = false">
             
             <div class="fixed top-0 right-0 w-[400px] h-[400px] bg-primary/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
             <div class="fixed bottom-0 left-0 w-[400px] h-[400px] bg-accent/20 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>
             
             {# Enlaces Mobile #}
             <div class="flex flex-col gap-6 text-center w-full px-6 py-24 z-10 my-auto"
                  x-show="isMobileMenuOpen"
                  x-transition:enter="transition ease-out duration-700 delay-100 transform"
                  x-transition:enter-start="opacity-0 translate-y-12"
                  x-transition:enter-end="opacity-100 translate-y-0"
                  x-transition:leave="transition ease-in duration-200"
                  x-transition:leave-start="opacity-100"
                  x-transition:leave-end="opacity-0">
                 
                <a href="{{ site.url }}" @click="isMobileMenuOpen = false" class="text-4xl font-display font-black text-white hover:text-primary transition-colors tracking-tight">Inicio</a>
                <a href="{{ site.url }}/nuestra-escuela" @click="isMobileMenuOpen = false" class="text-4xl font-display font-black text-white hover:text-primary transition-colors tracking-tight">Escuela</a>
                
                {# Dropdown Mobile (Acordeón) #}
                <div x-data="{ mobileCoursesOpen: false }" class="flex flex-col items-center">
                    <button @click="mobileCoursesOpen = !mobileCoursesOpen" class="flex items-center gap-2 text-4xl font-display font-black text-white hover:text-primary transition-colors tracking-tight focus:outline-none">
                        Cursos
                        <svg class="w-8 h-8 transition-transform duration-300" :class="mobileCoursesOpen ? 'rotate-180 text-primary' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
                    </button>
                    
                    <div x-show="mobileCoursesOpen" x-collapse.duration.300ms x-cloak class="flex flex-col gap-4 mt-6 mb-2">
                        <a href="{{ site.url }}/courses/licencia-clase-b" @click="isMobileMenuOpen = false" class="text-xl font-bold text-white/80 hover:text-white transition-colors">Licencia Clase B</a>
                        <a href="{{ site.url }}/courses/profesional-a2" @click="isMobileMenuOpen = false" class="text-xl font-bold text-white/80 hover:text-white transition-colors">Profesional A2</a>
                        <a href="{{ site.url }}/courses/profesional-a4" @click="isMobileMenuOpen = false" class="text-xl font-bold text-white/80 hover:text-white transition-colors">Profesional A4</a>
                        <a href="{{ site.url }}/empresas" @click="isMobileMenuOpen = false" class="text-xl font-bold text-white/80 hover:text-white transition-colors pt-2 mt-2 border-t border-white/20">Para empresas</a>
                    </div>
                </div>

                <a href="{{ site.url }}#contacto" @click="isMobileMenuOpen = false" class="text-4xl font-display font-black text-white hover:text-primary transition-colors tracking-tight">Contacto</a>
                <a href="https://practicatest.cl/escuela/abc-escuela-de-conductores-profesionales-en-providencia/Y5-Z?u=login" target="_blank" rel="nofollow noopener noreferrer" @click="isMobileMenuOpen = false" class="text-4xl font-display font-black text-white hover:text-primary transition-colors tracking-tight">PracticaTest</a>
             </div>

             {# Botones Inferiores Mobile #}
             <div class="w-full px-6 pb-8 flex flex-col gap-3 z-10 mt-auto"
                  x-show="isMobileMenuOpen"
                  x-transition:enter="transition ease-out duration-700 delay-200 transform"
                  x-transition:enter-start="opacity-0 translate-y-12"
                  x-transition:enter-end="opacity-100 translate-y-0"
                  x-transition:leave="transition ease-in duration-200"
                  x-transition:leave-start="opacity-100"
                  x-transition:leave-end="opacity-0">
                <a href="https://abcconduccion.cl/aulavirtual" target="_blank" rel="noopener" class="flex items-center justify-center gap-3 px-4 py-4 rounded-2xl font-bold uppercase tracking-widest text-[#0d2a45] bg-white border border-white/20 shadow-xl active:bg-gray-100 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Aula Virtual
                </a>
                <a href="https://www.webpay.cl/company/29034" target="_blank" rel="nofollow noopener noreferrer" class="flex items-center justify-center gap-3 px-5 py-4 rounded-2xl font-bold uppercase tracking-widest text-white bg-primary shadow-lg shadow-primary/40 outline outline-1 outline-primary/50 outline-offset-4 active:scale-95 transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                    Paga aquí
                </a>
             </div>
        </div>
    </template>
</nav>
