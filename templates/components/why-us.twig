{# Ubicación: templates/components/why-us.twig #}

{% set steps = [
    {
        title: 'Trayectoria Certificada',
        desc: 'Más de 21 años formando conductores seguros. Acreditados por el Ministerio de Transportes y OTEC (SENCE).',
        img: theme.link ~ '/assets/images/foto-abcconduccion-academia-conduccion_011.webp',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>',
        label: 'Aulas modernas'
    },
    {
        title: 'Profesores Expertos',
        desc: 'Instructores capacitados con más de 30 años de experiencia en las calles.',
        img: theme.link ~ '/assets/images/foto-abcconduccion-academia-conduccion_007.webp',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 22v-4a2 2 0 1 0-4 0v4"/><path d="m18 10 4 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-8l4-2"/><path d="M18 5v17"/><path d="m4 6 8-4 8 4"/><path d="M6 5v17"/><circle cx="12" cy="9" r="2"/></svg>',
        label: 'Instrucción en ruta'
    },
    {
        title: 'Equipamiento',
        desc: 'Laboratorio psicotécnico avanzado y una flota de vehículos modernos.',
        img: theme.link ~ '/assets/images/foto-abcconduccion-academia-conduccion_005.webp',
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>',
        label: 'Tecnología de punta'
    }
] %}

<section id="why-us" class="pt-16 pb-16 bg-background-light overflow-hidden relative"
         x-data="{ 
             progress: 0,
             updateScroll() {
                 let rect = this.$refs.roadContainer.getBoundingClientRect();
                 let vh = window.innerHeight;
                 let scrolled = (vh / 1.5) - rect.top;
                 let percent = (scrolled / rect.height) * 100;
                 this.progress = Math.max(0, Math.min(100, percent));
             }
         }"
         @scroll.window="updateScroll"
         x-ref="roadContainer">

    <div class="absolute left-1/2 top-0 bottom-0 w-24 -translate-x-1/2 hidden md:block z-0">
        <div class="absolute inset-y-0 left-1/2 w-0 -translate-x-1/2 border-l-2 border-dashed border-gray-300"></div>
        <div class="absolute top-0 left-1/2 w-1 -translate-x-1/2 bg-primary transition-all duration-500 ease-out" 
             :style="'height: ' + progress + '%'">
             <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 bg-white p-2 rounded-full shadow-lg text-primary ring-4 ring-background-light z-30 transition-opacity duration-200"
                  :class="progress >= 99.5 ? 'opacity-0' : 'opacity-100'">
                  <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
             </div>
        </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 relative z-10">
        
        <div class="text-center mb-16 bg-[rgba(250,250,250,0.5)] rounded-3xl">
            <h2 class="text-primary font-black tracking-[0.3em] uppercase text-xs mb-3">Trayectoria</h2>
            <h2 class="text-4xl font-bold mb-4 tracking-tight font-display">Tu ruta hacia el éxito</h2>
            <p class="text-muted text-base max-w-xl mx-auto font-medium">Nuestra experiencia y equipamiento garantizan tu seguridad frente al volante.</p>
        </div>

        <div class="relative space-y-8 z-10">
{% for step in steps %}
    <div x-data="{ active: false }"
         @scroll.window="active = (($el.getBoundingClientRect().top + ($el.offsetHeight / 2)) <= (window.innerHeight / 1.5))"
         class="flex flex-col md:flex-row items-center gap-20 {{ loop.index is even ? 'md:flex-row-reverse' : '' }}">
        
        <div class="w-full md:w-1/2 relative z-30">
            <div class="bg-white rounded-3xl p-4 md:p-6 shadow-float border-b-8 transition-colors duration-500 group hover:-translate-y-2 relative overflow-hidden"
                 :class="active ? 'border-primary' : 'border-gray-200'">
                
                <div class="flex items-center gap-4 mb-5">
                    <div class="w-12 h-12 rounded-2xl text-white flex items-center justify-center shadow-lg transition-colors duration-500 group-hover:rotate-6"
                         :class="active ? 'bg-primary' : 'bg-gray-300'">
                        {{ step.icon|raw }}
                    </div>
                    <h3 class="text-2xl font-bold leading-tight font-display text-text-main">{{ step.title }}</h3>
                </div>
                <p class="text-[#888] text-base mb-4 leading-relaxed font-medium font-body">{{ step.desc }}</p>
                
                <div class="relative rounded-2xl overflow-hidden h-64 shadow-inner">
                    <img src="{{ step.img }}" alt="{{ step.title }}" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105">
                    <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/10 to-transparent opacity-70"></div>
                    <div class="absolute bottom-4 left-4 flex items-center gap-2">
                        <div class="w-2 h-2 bg-primary rounded-full animate-pulse"></div>
                        <span class="text-white text-[0.625rem] font-black uppercase tracking-[0.2em]">{{ step.label }}</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-10 h-10 rounded-full bg-white border-[5px] items-center justify-center z-20 transition-colors duration-500"
             :class="active ? 'border-primary' : 'border-gray-200'">
            <div class="w-3 h-3 rounded-full transition-all duration-500"
                 :class="active ? 'bg-primary scale-100' : 'bg-transparent scale-0'"></div>
            <div class="absolute z-0 h-1 w-12 transition-colors duration-500 {{ loop.index is even ? 'left-full' : 'right-full' }}"
                 :class="active ? 'bg-primary/30' : 'bg-gray-200'"></div>
        </div>

        <div class="hidden md:block w-1/2"></div>
    </div>
{% endfor %}
        </div>
    </div>
</section>