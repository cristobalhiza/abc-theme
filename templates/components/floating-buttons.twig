{# Ubicación: templates/components/floating-buttons.twig #}
{# Componente global: Botones flotantes (WhatsApp, Back-to-top, CTA Inscripción) #}

<div x-data="floatingButtons()" x-init="init()" class="fixed bottom-0 right-0 z-50 pointer-events-none">

    {# ═══════════════════════════════════════════════════ #}
    {# 1. BOTÓN WHATSAPP                                   #}
    {# ═══════════════════════════════════════════════════ #}
    <div class="fixed bottom-6 right-6 flex flex-col items-end gap-3 pointer-events-auto">

        {# Tooltip "¿Necesitas ayuda?" #}
        <div x-show="showTooltip && !tooltipDismissed"
             x-transition:enter="transition ease-out duration-500"
             x-transition:enter-start="opacity-0 translate-y-4 scale-95"
             x-transition:enter-end="opacity-100 translate-y-0 scale-100"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-start="opacity-100 scale-100"
             x-transition:leave-end="opacity-0 translate-y-2 scale-95"
             x-cloak
             class="relative bg-white rounded-2xl shadow-xl px-4 py-3 border border-gray-100 max-w-[200px] cursor-default"
             @click.stop>
            
            {# Flecha del tooltip apuntando hacia abajo (diagonal al botón) #}
            <div class="absolute right-5 -bottom-2 w-4 h-4 bg-white border-r border-b border-gray-100 rotate-45"></div>
            
            <button @click="tooltipDismissed = true" 
                    class="absolute -top-2 -right-2 w-5 h-5 bg-gray-200 hover:bg-gray-300 rounded-full flex items-center justify-center transition-colors"
                    aria-label="Cerrar">
                <svg class="w-3 h-3 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            
            <p class="text-xs font-semibold text-text leading-snug">¿Necesitas ayuda? 👋</p>
            <p class="text-[0.65rem] text-muted mt-0.5">Escríbenos por WhatsApp</p>
        </div>

        {# Botón principal WhatsApp #}
        <a href="https://api.whatsapp.com/send?phone=56992199314&text=%C2%A1Hola!%20Necesito%20m%C3%A1s%20informaci%C3%B3n...."
           target="_blank"
           rel="noopener noreferrer"
           aria-label="Contactar por WhatsApp"
           class="group relative flex items-center justify-center w-[60px] h-[60px] rounded-full shadow-lg transition-all duration-300 hover:scale-110 hover:shadow-xl"
           style="background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);"
           @mouseenter="tooltipDismissed = true">
            
            {# Pulse ring #}
            <span class="absolute inset-0 rounded-full animate-ping opacity-20" style="background-color: #25D366;"></span>
            
            {# WhatsApp SVG icon #}
            <svg class="w-7 h-7 text-white relative z-10" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
        </a>
    </div>

    {# ═══════════════════════════════════════════════════ #}
    {# 2. BOTÓN SCROLL-TO-TOP (mobile-first, sutil)        #}
    {# ═══════════════════════════════════════════════════ #}
    <button x-show="showBackToTop"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 translate-y-4 scale-90"
            x-transition:enter-end="opacity-100 translate-y-0 scale-100"
            x-transition:leave="transition ease-in duration-200"
            x-transition:leave-start="opacity-100 scale-100"
            x-transition:leave-end="opacity-0 translate-y-4 scale-90"
            x-cloak
            @click="window.scrollTo({ top: 0, behavior: 'smooth' })"
            aria-label="Volver arriba"
            class="fixed bottom-6 left-6 pointer-events-auto w-11 h-11 bg-white/90 backdrop-blur-sm border border-gray-200 rounded-full flex items-center justify-center shadow-md hover:shadow-lg hover:bg-white hover:-translate-y-0.5 transition-all duration-200 group">
        <svg class="w-4 h-4 text-muted group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
        </svg>
    </button>

    {# ═══════════════════════════════════════════════════ #}
    {# 3. CTA INSCRIPCIÓN FLOTANTE (inteligente)           #}
    {#    Aparece tras pasar el hero, se oculta cuando      #}
    {#    el formulario de contacto es visible               #}
    {# ═══════════════════════════════════════════════════ #}
    <div x-show="showCTA"
         x-transition:enter="transition ease-out duration-500"
         x-transition:enter-start="opacity-0 translate-y-8 scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100"
         x-transition:leave="transition ease-in duration-300"
         x-transition:leave-start="opacity-100 translate-y-0 scale-100"
         x-transition:leave-end="opacity-0 translate-y-8 scale-95"
         x-cloak
         class="fixed bottom-6 left-1/2 -translate-x-1/2 z-40 md:hidden pointer-events-auto">
        
        <a href="#contacto"
           @click="scrollToContact($event)"
           class="flex items-center justify-center gap-2 px-6 py-3.5 bg-white/95 backdrop-blur-md text-primary font-display font-bold text-[0.8rem] uppercase tracking-wider rounded-full shadow-lg shadow-primary/20 border border-primary/10 transition-transform active:scale-95 whitespace-nowrap">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
            </svg>
            Inscríbete
        </a>
    </div>

</div>

{# ═══════════════════════════════════════════════════════ #}
{# LÓGICA ALPINE.JS                                       #}
{# ═══════════════════════════════════════════════════════ #}
<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('floatingButtons', () => ({
        showTooltip: false,
        tooltipDismissed: false,
        showBackToTop: false,
        showCTA: false,
        heroBottom: 0,
        contactVisible: false,

        init() {
            // Mostrar tooltip del WhatsApp después de 6 segundos
            setTimeout(() => {
                this.showTooltip = true;
                // Auto-ocultar después de 12 segundos
                setTimeout(() => {
                    this.tooltipDismissed = true;
                }, 12000);
            }, 6000);

            // Observar el scroll para back-to-top y CTA
            window.addEventListener('scroll', () => this.onScroll(), { passive: true });
            
            // Intersection Observer para la sección de contacto
            this.observeContactSection();
        },

        onScroll() {
            const scrollY = window.scrollY;
            const viewHeight = window.innerHeight;

            // Back-to-top: mostrar después de 1.5 pantallas de scroll
            this.showBackToTop = scrollY > viewHeight * 1.5;

            // CTA: mostrar después de pasar el hero (primera pantalla)
            // y ocultar si la sección contacto es visible
            this.showCTA = scrollY > viewHeight * 0.8 && !this.contactVisible;
        },

        observeContactSection() {
            const contactEl = document.getElementById('contacto');
            if (!contactEl) return;

            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach(entry => {
                        this.contactVisible = entry.isIntersecting;
                        // Re-evaluar CTA
                        this.showCTA = window.scrollY > window.innerHeight * 0.8 && !this.contactVisible;
                    });
                },
                { threshold: 0.2 }
            );
            observer.observe(contactEl);
        },

        scrollToContact(e) {
            e.preventDefault();
            const el = document.getElementById('contacto');
            if (el) {
                el.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }
    }));
});
</script>

<style>
    @media (max-width: 767px) {
        body {
            scroll-padding-bottom: 80px;
        }
    }
</style>
