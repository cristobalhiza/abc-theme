<section x-data="{ mounted: false }" x-init="setTimeout(() => mounted = true, 100)" class="relative min-h-screen flex items-center overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center w-full">
        
        {# Columna Izquierda: Textos y CTA #}
        <div class="flex flex-col items-start space-y-8 transition-all duration-1000 ease-out transform"
             :class="mounted ? 'opacity-100 translate-x-0' : 'opacity-0 -translate-x-12'">
            
            <div class="flex flex-wrap gap-3">
                <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-white shadow-sm text-sm font-medium text-primary border border-primary/10">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path><path d="m9 12 2 2 4-4"></path></svg>
                    Ministerio de Transportes
                </span>
                <span class="inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-white shadow-sm text-sm font-medium text-primary border border-primary/10">
                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 22v-4a2 2 0 1 0-4 0v4"></path><path d="m18 10 4 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-8l4-2"></path><path d="M18 5v17"></path><path d="m4 6 8-4 8 4"></path><path d="M6 5v17"></path><circle cx="12" cy="9" r="2"></circle></svg>
                    OTEC (SENCE)
                </span>
            </div>
            
            <div class="space-y-4">
                <h1 class="font-display font-bold text-5xl md:text-7xl leading-[1.1] tracking-tight text-text-main">
                    ABC Escuela <br />
                    <span class="text-primary relative inline-block">
                        de Conductores.
                        <svg class="absolute -bottom-2 left-0 w-full text-primary/20" fill="none" viewBox="0 0 200 12" xmlns="http://www.w3.org/2000/svg">
                            <path d="M2 9.5C50 -2.5 150 -2.5 198 9.5" stroke="currentColor" stroke-linecap="round" stroke-width="4"></path>
                        </svg>
                    </span>
                </h1>
                <p class="text-xl text-muted font-medium max-w-xl leading-relaxed">
                    Formando conductores desde <strong class="text-text-main">2001</strong>. Más de dos décadas de trayectoria. Especializados en Licencias Clase B, A2 y A4.
                </p>
            </div>

            <button class="group bg-primary text-white px-8 py-4 rounded-xl font-display font-bold text-lg flex items-center gap-2 hover:-translate-y-1 transition-all shadow-lg hover:shadow-primary/30 uppercase tracking-wide">
                Inicia tu viaje 
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
            </button>
        </div>

        {# Columna Derecha: Imágenes y Tarjetas Flotantes #}
        <div class="relative transition-all duration-1000 delay-200 ease-out transform"
             :class="mounted ? 'opacity-100 translate-x-0 scale-100' : 'opacity-0 translate-x-12 scale-95'">
            <div class="absolute inset-0 bg-primary/5 rounded-full blur-3xl scale-90"></div>
            
            <div class="relative bg-white/80 backdrop-blur-md rounded-[32px] p-4 shadow-float border border-white animate-float">
                {# Cambiamos a aspect-[4/3] para que no sea un cuadrado perfecto y quite altura #}
                <div class="rounded-[24px] overflow-hidden aspect-[4/3]">
                    <img src="{{ theme.link }}/assets/images/abc-conduccion-academia-hero-section.webp" alt="Flota de vehículos ABC" class="w-full h-full object-cover" />
                    
                    {# Mantenemos solo el escudo rotado inferior como detalle estético #}
                    <div class="absolute bottom-6 right-6">
                        <div class="bg-accent text-white w-12 h-12 rounded-full flex items-center justify-center shadow-lg rotate-12">
                            <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path><path d="m9 12 2 2 4-4"></path></svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Indicador de Scroll Inferior #}
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center">
        <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-muted mb-4 opacity-50">Descubre tu ruta</span>
        <div class="relative w-12 h-12 flex items-center justify-center">
            <div class="absolute inset-0 rounded-full border-2 border-primary/30 animate-ping"></div>
            <div class="w-3 h-3 bg-primary rounded-full shadow-[0_0_15px_rgba(6,131,192,0.6)]"></div>
        </div>
    </div>
</section>