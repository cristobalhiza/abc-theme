{% extends "base.twig" %}

{% block content %}
<main class="flex-grow flex flex-col items-center justify-center px-6 py-20 relative overflow-hidden min-h-[80vh]">
    <!-- Abstract Road Illustration with Broken Path -->
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
        <svg class="w-full h-full opacity-10 text-primary" preserveAspectRatio="none" viewBox="0 0 1440 800">
            <path class="road-line" style="stroke-dasharray: 1000; stroke-dashoffset: 0;" d="M-100,400 C300,400 500,200 800,200 S1200,600 1600,600" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="20"></path>
            <path class="road-line text-accent" style="stroke-dasharray: 20 20;" d="M800,200 C850,200 900,100 920,50" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="12"></path>
        </svg>
    </div>
    
    <div class="z-10 max-w-4xl w-full flex flex-col items-center text-center mt-16 pb-12">
        <!-- Creative 404 Illustration Area -->
        <div class="relative mb-12">
            <div class="bg-white p-8 md:p-12 rounded-[32px] shadow-float relative border border-gray-100 text-primary">
                <!-- Ícono de SVG Vehículo -->
                <svg class="w-32 h-32" fill="currentColor" viewBox="0 0 24 24"><path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.85 7h10.28l1.08 3.11H5.77L6.85 7zM19 17H5v-5h14v5z"/><circle cx="7.5" cy="14.5" r="1.5"/><circle cx="16.5" cy="14.5" r="1.5"/></svg>
                
                <div class="absolute -top-4 -right-4 bg-accent text-white p-3 md:p-4 rounded-full shadow-lg border-4 border-white">
                    <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </div>
            </div>
            <!-- Broken Road Line Accent -->
            <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 w-48 h-2 bg-primary rounded-full opacity-20"></div>
        </div>
        
        <!-- Content -->
        <h1 class="font-display text-5xl md:text-7xl font-bold tracking-tight text-text-main mb-6">
            404 - Ruta No Encontrada
        </h1>
        <div class="max-w-2xl">
            <p class="font-body text-xl md:text-2xl text-muted font-medium leading-relaxed mb-4">
                Incluso los mejores conductores toman un camino equivocado a veces.
            </p>
            <p class="font-body text-lg text-gray-500 mb-10">
                Parece que has tomado un desvío inesperado. Volvamos a la ruta principal para que sigas avanzando hacia tu licencia.
            </p>
        </div>
        
        <!-- CTA -->
        <a href="{{ site.url }}" class="group flex items-center justify-center gap-3 bg-primary hover:brightness-110 text-white font-display text-lg font-bold px-10 py-5 rounded-2xl transition-all duration-300 transform active:scale-95 shadow-lg shadow-primary/30 w-full sm:w-auto">
            <svg class="w-6 h-6 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Regresar al Inicio
        </a>
        
        <!-- Bento Grid - Suggested Alternatives -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-24 w-full">
            <a href="{{ site.url }}#courses" class="bg-white p-6 md:p-8 flex flex-col items-center md:items-start text-center md:text-left rounded-[32px] border border-gray-100 shadow-float hover:border-primary/30 hover:shadow-xl transition-all duration-500 group">
                <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center mb-6 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"/></svg>
                </div>
                <h3 class="font-display text-2xl font-bold mb-3">Cursos</h3>
                <p class="font-body text-base text-muted">Explora nuestras categorías de licencias disponibles.</p>
            </a>
            
            <a href="{{ site.url }}/nuestra-escuela" class="bg-white p-6 md:p-8 flex flex-col items-center md:items-start text-center md:text-left rounded-[32px] border border-gray-100 shadow-float hover:border-primary/30 hover:shadow-xl transition-all duration-500 group">
                <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center mb-6 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <h3 class="font-display text-2xl font-bold mb-3">Nuestra Escuela</h3>
                <p class="font-body text-base text-muted">Descubre nuestro equipamiento e instalaciones.</p>
            </a>
            
            <a href="{{ site.url }}#contacto" class="bg-white p-6 md:p-8 flex flex-col items-center md:items-start text-center md:text-left rounded-[32px] border border-gray-100 shadow-float hover:border-primary/30 hover:shadow-xl transition-all duration-500 group">
                <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center mb-6 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                </div>
                <h3 class="font-display text-2xl font-bold mb-3">Contacto</h3>
                <p class="font-body text-base text-muted">¿Necesitas asistencia? Nuestro equipo está listo.</p>
            </a>
        </div>
    </div>
</main>
{% endblock %}
