<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ wp_title }}</title>
    <link rel="stylesheet" href="{{ site.theme.uri }}/style.css">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    {{ function('wp_head') }}
</head>
<body class="bg-background-light text-text-main font-body antialiased selection:bg-primary selection:text-white">
    <nav x-data="{ isScrolled: false, isMobileMenuOpen: false }" 
         @scroll.window="isScrolled = (window.pageYOffset > 20)"
         :class="isScrolled ? 'bg-white/80 backdrop-blur-md shadow-sm py-3' : 'bg-transparent py-5'"
         class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
<div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
        <a href="{{ site.url }}" class="flex items-center transition-transform hover:scale-105">
            <img src="{{ theme.link }}/assets/logos/ABC-logo-nobg.webp" 
                 alt="Logo ABC Academia de Conducción" 
                 :class="isScrolled ? 'h-10' : 'h-14'"
                 class="w-auto transition-all duration-500 object-contain" />
        </a>
            
            <div class="hidden md:flex items-center gap-6">
                <a href="{{ site.url }}" class="text-[0.8rem] font-bold uppercase tracking-widest text-text-main hover:text-primary transition-colors">Inicio</a>
                <a href="{{ site.url }}/nuestra-escuela" class="text-[0.8rem] font-bold uppercase tracking-widest text-text-main hover:text-primary transition-colors">Escuela</a>
                <a href="{{ site.url }}#courses" class="text-[0.8rem] font-bold uppercase tracking-widest text-text-main hover:text-primary transition-colors">Cursos</a>
                <a href="{{ site.url }}#contacto" class="text-[0.8rem] font-bold uppercase tracking-widest text-text-main hover:text-primary transition-colors">Contacto</a>
                
                <div class="w-px h-6 bg-gray-200 mx-1"></div>

                <a href="https://abcconduccion.cl/aulavirtual" target="_blank" rel="noopener" class="flex items-center gap-2 px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-widest text-primary bg-primary/5 border border-primary/20 hover:bg-primary/10 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    Aula Virtual
                </a>
                <a href="https://www.webpay.cl/company/29034" target="_blank" rel="nofollow noopener noreferrer" class="flex items-center gap-2 px-5 py-2.5 rounded-xl text-xs font-bold uppercase tracking-widest text-white bg-primary hover:brightness-110 shadow-lg shadow-primary/30 transition-all hover:-translate-y-0.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                    Paga aquí
                </a>
            </div>
        </div>
    </nav>

    <div class="min-h-screen">
        {% block content %}{% endblock %}
    </div>

    {{ function('wp_footer') }}
</body>
</html>