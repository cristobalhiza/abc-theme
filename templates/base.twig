<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ wp_title }}</title>
    <link rel="stylesheet" href="{{ site.theme.uri }}/style.css">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    {{ function('wp_head') }}
</head>
<body class="bg-background-light text-text-main font-body antialiased selection:bg-primary selection:text-white">
    <nav x-data="{ isScrolled: false, isMobileMenuOpen: false }" 
         @scroll.window="isScrolled = (window.pageYOffset > 20)"
         :class="isScrolled ? 'bg-white/80 backdrop-blur-md shadow-sm py-3' : 'bg-transparent py-5'"
         class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
<div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
        <a href="{{ site.url }}" class="flex items-center transition-transform hover:scale-105">
            <img src="{{ theme.link }}/assets/logos/ABC-logo-nobg.webp" 
                 alt="Logo ABC Academia de Conducción" 
                 :class="isScrolled ? 'h-10' : 'h-14'"
                 class="w-auto transition-all duration-500 object-contain" />
        </a>
            
            <div class="hidden md:flex items-center gap-8">
                <a href="{{ site.url }}" class="text-sm font-medium uppercase tracking-wide text-text-main hover:text-primary transition-colors">Inicio</a>
                <a href="#" class="text-sm font-medium uppercase tracking-wide text-text-main hover:text-primary transition-colors">Cursos</a>
                <a href="#" class="text-sm font-medium uppercase tracking-wide text-text-main hover:text-primary transition-colors">Contacto</a>
                <a href="https://abcconduccion.cl/aulavirtual" target="_blank" rel="noopener" class="text-sm font-medium uppercase tracking-wide text-text-main hover:text-primary transition-colors">Aula Virtual</a>
                <a href="https://www.webpay.cl/company/29034" target="_blank" rel="nofollow noopener noreferrer" class="text-sm font-medium uppercase tracking-wide text-text-main hover:text-primary transition-colors">Paga aquí</a>
            </div>
        </div>
    </nav>

    <div class="min-h-screen">
        {% block content %}{% endblock %}
    </div>

    {{ function('wp_footer') }}
</body>
</html>