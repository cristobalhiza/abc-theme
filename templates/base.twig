<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ wp_title }}</title>
    <link rel="stylesheet" href="{{ site.theme.uri }}/style.css?v={{ "now"|date('U') }}">
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/intersect@3.x.x/dist/cdn.min.js"></script> 
    <script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>[x-cloak] { display: none !important; }</style>
    {{ function('wp_head') }}
</head>
<body class="bg-background-light text-text-main font-body antialiased selection:bg-primary selection:text-white">
    {% include 'components/navbar.twig' %}

    <div class="min-h-screen">
        {% block content %}{% endblock %}
    </div>
    {% include 'components/contact-modal.twig' %}

    {% include 'templates/components/floating-buttons.twig' %}

    {% include 'templates/components/footer.twig' %}

    {{ function('wp_footer') }}
</body>
</html>