{% extends "base.twig" %}

{% block content %}
<main class="max-w-7xl mx-auto px-6 py-12">
    
    {# Cabecera del Curso (Estilo Hero) #}
    <div class="mb-12">
        <div class="flex items-center gap-2 text-primary mb-4">
            <span class="h-1 w-12 bg-primary rounded-full"></span>
            <span class="text-sm font-bold uppercase tracking-widest">Detalle del Curso</span>
        </div>
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-text-main font-display">
            {{ post.title }}
        </h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        
        {# Columna Principal #}
        <section class="lg:col-span-2 space-y-8">
            {% if img_secundaria %}
                <div class="h-80 relative overflow-hidden rounded-[24px] shadow-float border border-transparent">
                    <img src="{{ img_secundaria }}" alt="{{ post.title }}" class="w-full h-full object-cover">
                </div>
            {% endif %}

            <div class="bg-white rounded-[24px] p-8 shadow-float border border-gray-50">
                <h3 class="text-2xl font-bold text-text-main mb-6 font-display">Descripción General</h3>
                <div class="prose max-w-none text-muted font-medium leading-relaxed">
                    {{ post.content }}
                </div>
            </div>

            {# Requisitos y Resolución Legal #}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {% if pdf_requisitos %}
                    <a href="{{ pdf_requisitos }}" target="_blank" class="group flex items-center gap-4 p-6 bg-surface rounded-[24px] shadow-float border border-gray-50 hover:-translate-y-1 transition-all duration-300">
                        <div class="w-12 h-12 rounded-full bg-primary/10 text-primary flex items-center justify-center group-hover:bg-primary group-hover:text-white transition-colors">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                        </div>
                        <div>
                            <p class="font-bold text-text-main text-lg">Requisitos</p>
                            <p class="text-sm text-primary font-semibold">Descargar PDF</p>
                        </div>
                    </a>
                {% endif %}

                {% if resolucion_pdf %}
                    <a href="{{ resolucion_pdf }}" target="_blank" class="group flex items-center gap-4 p-6 bg-surface rounded-[24px] shadow-float border border-gray-50 hover:-translate-y-1 transition-all duration-300">
                        <div class="w-12 h-12 rounded-full bg-accent/10 text-accent flex items-center justify-center group-hover:bg-accent group-hover:text-white transition-colors">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <div>
                            <p class="font-bold text-text-main text-sm">{{ resolucion_texto|default('Resolución Legal') }}</p>
                            <p class="text-sm text-accent font-semibold">Ver Documento</p>
                        </div>
                    </a>
                {% endif %}
            </div>
        </section>

        {# Sidebar Derecho (Tarjetas de Valores y Descargas) #}
        <aside class="space-y-8">
            <div class="bg-surface rounded-[24px] p-8 shadow-float border border-primary ring-4 ring-primary/5">
                <div class="inline-block px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-accent text-white mb-6">
                    Inscripción Abierta
                </div>
                
                <div class="space-y-4 mb-8">
                    <div class="flex justify-between items-end pb-4 border-b border-gray-100">
                        <span class="text-muted font-semibold">Valor Normal</span>
                        <span class="text-xl font-bold text-text-main font-display">${{ precio_normal|number_format(0, ',', '.') }}</span>
                    </div>
                    {% if precio_oferta %}
                    <div class="flex justify-between items-end pb-4 border-b border-gray-100">
                        <span class="text-muted font-semibold">Valor Oferta</span>
                        <span class="text-3xl font-black text-primary font-display">${{ precio_oferta|number_format(0, ',', '.') }}</span>
                    </div>
                    {% endif %}
                </div>

                <button class="w-full h-14 bg-primary text-white rounded-xl font-bold uppercase tracking-wide flex items-center justify-center gap-2 hover:brightness-110 shadow-lg transition-all group">
                    Matricularme <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </button>
            </div>

            {% if descargas is not empty %}
                <div class="bg-surface rounded-[24px] p-8 shadow-float border border-gray-50">
                    <h3 class="text-xl font-bold text-text-main mb-6 font-display">Material de Estudio</h3>
                    <ul class="space-y-4">
                        {% for descarga in descargas %}
                            {% if descarga.archivo %}
                            <li>
                                <a href="{{ descarga.archivo }}" target="_blank" class="flex items-center gap-3 group p-3 -mx-3 rounded-xl hover:bg-background-light transition-colors">
                                    <div class="p-2 bg-primary/10 rounded-lg text-primary group-hover:bg-primary group-hover:text-white transition-colors">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                    </div>
                                    <span class="font-semibold text-text-main group-hover:text-primary transition-colors">{{ descarga.titulo|default('Documento') }}</span>
                                </a>
                            </li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
        </aside>

    </div>
</main>
{% endblock %}