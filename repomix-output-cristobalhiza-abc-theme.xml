<section id="why-us" class="pt-16 pb-16 bg-background-light overflow-hidden relative"
         x-data="{ 
             progress: 0,
             updateScroll() {
                 let rect = this.$refs.roadContainer.getBoundingClientRect();
                 let vh = window.innerHeight;
                 let scrolled = (vh / 1.5) - rect.top;
                 let percent = (scrolled / rect.height) * 100;
                 this.progress = Math.max(0, Math.min(100, percent));
             }
         }"
         @scroll.window="updateScroll"
         x-ref="roadContainer">

    <div class="absolute left-1/2 top-0 bottom-0 w-24 -translate-x-1/2 hidden md:block z-0">
        <div class="absolute inset-y-0 left-1/2 w-0 -translate-x-1/2 border-l-2 border-dashed border-gray-300"></div>
        <div class="absolute top-0 left-1/2 w-1 -translate-x-1/2 bg-primary transition-all duration-500 ease-out" 
             :style="'height: ' + progress + '%'">
             <div class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-1/2 bg-white p-2 rounded-full shadow-lg text-primary ring-4 ring-background-light z-30 transition-opacity duration-200"
                  :class="progress >= 99.5 ? 'opacity-0' : 'opacity-100'">
                  <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
             </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        
        <div class="text-center mb-16">
            <span class="block text-primary font-black tracking-[0.3em] uppercase text-xs mb-3">Casos de Éxito</span>
            <h2 class="text-4xl font-bold mb-4 tracking-tight font-display text-text-main">Lo que dicen nuestros alumnos</h2>
            <p class="text-muted text-base max-w-xl mx-auto font-medium">Nuestra experiencia y equipamiento garantizan tu seguridad frente al volante.</p>
        </div>

        <div class="relative space-y-8 md:space-y-0 z-10">
{% for step in steps %}
    <div x-data="{ active: false }"
         @scroll.window="active = (($el.getBoundingClientRect().top + ($el.offsetHeight / 2)) <= (window.innerHeight / 1.5))"
         class="flex flex-col md:flex-row items-center relative {{ loop.index is even ? 'md:flex-row-reverse' : '' }} 
                md:py-16
                bg-white md:bg-transparent rounded-[32px] p-5 md:p-0 shadow-float md:shadow-none border-b-8 md:border-b-0 transition-colors duration-500 group"
         :class="active ? 'border-primary md:border-transparent' : 'border-gray-200 md:border-transparent'">
        
        <!-- Lado de la Tarjeta Visual -->
        <div class="w-full md:w-1/2 relative z-30 order-2 md:order-none {{ loop.index is even ? 'md:pl-[72px]' : 'md:pr-[72px]' }}">
            
            <!-- Marco blanco exclusivo de desktop -->
            <div class="md:bg-white md:rounded-[32px] md:p-5 lg:p-6 md:shadow-float border-0 md:border-b-8 transition-colors duration-500"
                 :class="active ? 'md:border-primary' : 'md:border-gray-200'">
                 
                 <!-- Contenedor interno de la imagen -->
                <div class="rounded-2xl overflow-hidden relative h-64 md:h-auto md:aspect-video shadow-inner group-hover/img:shadow-lg transition-all duration-500">
                    <img src="{{ step.img }}" alt="{{ step.title }}" class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000" :class="active ? 'scale-105' : 'scale-100'">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent transition-opacity duration-500" :class="active ? 'opacity-80' : 'opacity-40'"></div>
                    
                    <div class="absolute bottom-4 left-4 flex items-center gap-3 transition-transform duration-500" :class="active ? 'translate-y-0 opacity-100' : 'translate-y-4 opacity-0'">
                        <div class="w-2.5 h-2.5 md:w-3 md:h-3 bg-primary rounded-full animate-pulse shadow-[0_0_12px_rgba(255,160,0,0.8)]"></div>
                        <span class="text-white text-xs md:text-sm font-black uppercase tracking-[0.2em]">{{ step.label }}</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Nodo Central y Línea Estructural (Oculto en móvil) -->
        <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 w-10 h-10 rounded-full bg-white border-[5px] items-center justify-center z-20 transition-colors duration-500"
             :class="active ? 'border-primary' : 'border-gray-200'">
            <div class="w-3 h-3 rounded-full transition-all duration-500"
                 :class="active ? 'bg-primary scale-100' : 'bg-transparent scale-0'"></div>
            <!-- La línea mide exactamente 52px de ancho. Sumados a los 20px del radio del nodo, dan exactamente 72px, que calza milimétricamente con el padding horizontal -->
            <div class="absolute z-0 h-1 w-[52px] transition-all duration-500 {{ loop.index is even ? 'md:right-full md:origin-right' : 'md:left-full md:origin-left' }}"
                 :class="active ? 'bg-primary/30 scale-x-100' : 'bg-gray-200 scale-x-0'"></div>
        </div>

        <!-- Lado del Contenido y Texto -->
        <div class="w-full md:w-1/2 relative z-30 flex flex-col order-1 md:order-none pb-6 md:pb-0 
                    items-start text-left 
                    {{ loop.index is even ? 'md:items-end md:text-right md:pr-[72px]' : 'md:items-start md:text-left md:pl-[72px]' }}">
            
            <div class="flex items-center md:items-start md:flex-col gap-4 md:gap-0 mb-4 md:mb-6 w-full md:w-auto 
                        justify-start {{ loop.index is even ? 'md:justify-end md:items-end' : 'md:justify-start' }}">
                <div class="w-12 h-12 md:w-14 md:h-14 shrink-0 rounded-2xl text-white flex items-center justify-center shadow-lg transition-all duration-500 md:mb-6"
                     :class="active ? 'bg-primary shadow-primary/40 md:-translate-y-2' : 'bg-gray-300 translate-y-0'">
                    {{ step.icon|raw }}
                </div>
                <h3 class="text-2xl md:text-3xl lg:text-4xl font-bold leading-tight font-display transition-colors duration-500"
                    :class="active ? 'text-primary' : 'text-text-main'">{{ step.title }}</h3>
            </div>
                
            <p class="text-[#888] md:text-muted text-base md:text-lg leading-relaxed font-medium font-body mb-0 md:mb-8 transition-opacity duration-500 md:max-w-sm"
               :class="active ? 'opacity-100' : 'opacity-50'">{{ step.desc }}</p>
            
            <a href="/escuela" class="hidden md:inline-flex items-center gap-2 font-bold uppercase tracking-widest text-sm transition-colors duration-300 group/link mt-auto"
               :class="active ? 'text-primary hover:text-accent' : 'text-gray-400'">
                <span class="relative">
                   Nuestra Escuela
                   <span class="absolute -bottom-1 left-0 w-full h-[2px] bg-accent transition-transform duration-300 
                                scale-x-0 group-hover/link:scale-x-100 
                                {{ loop.index is even ? 'md:origin-right' : 'md:origin-left' }}"
                         :class="active ? '' : 'hidden'"></span>
                </span>
                <svg class="w-5 h-5 transition-transform duration-300 group-hover/link:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
        </div>
        
    </div>
{% endfor %}
        </div>
    </div>
</section>
</file>

<file path="templates/components/contact-modal.twig">
{# Ubicación: templates/components/contact-modal.twig #}

<div x-data="{ isOpen: false }"
     @open-contact-modal.window="
        isOpen = true; 
        if ($event.detail && $event.detail.course) {
            $dispatch('preselect-course', $event.detail.course);
        }
     "
     @keydown.escape.window="isOpen = false"
     x-show="isOpen"
     class="fixed inset-0 z-[100] flex items-center justify-center overflow-y-auto overflow-x-hidden bg-text-main/40 backdrop-blur-sm"
     x-cloak>

    {# Fondo oscuro que cierra el modal al hacer clic #}
    <div class="fixed inset-0" @click="isOpen = false"></div>

    {# Contenedor principal del modal con animaciones #}
    <div class="relative w-full max-w-md p-6 mx-auto z-10"
         x-show="isOpen"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 translate-y-8 scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 translate-y-0 scale-100"
         x-transition:leave-end="opacity-0 translate-y-8 scale-95">

        <div class="relative bg-white rounded-4xl shadow-2xl p-8 md:p-10 border border-gray-100"
             x-data="contactForm()"
             @submit.prevent="submitForm">

            {# Botón de cerrar superior derecho #}
            <button @click="isOpen = false" type="button" class="absolute top-5 right-5 p-2 text-muted hover:text-primary transition-colors rounded-full hover:bg-background-light focus:outline-none">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>

            <div class="text-center mb-8 mt-2">
                <h2 class="text-3xl font-bold tracking-tight font-display text-text-main mb-2">Inicia tu Aprendizaje</h2>
                <p class="text-[#666] text-sm font-medium">Déjanos tus datos y te contactaremos para tu matrícula.</p>
            </div>
            
            {# Estado de Éxito #}
            <div x-show="isSuccess" x-cloak class="flex flex-col items-center text-center py-4" x-transition.opacity>
                <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-4">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <h3 class="text-2xl font-bold text-text-main font-display mb-2">¡Mensaje Enviado!</h3>
                <p class="text-muted font-medium mb-6">Te contactaremos a la brevedad para afinar los detalles de tu solicitud.</p>
                <button @click="isOpen = false; setTimeout(() => resetForm(), 300)" type="button" class="w-full h-12 bg-background-light text-text-main rounded-xl font-bold uppercase tracking-wide hover:bg-gray-200 transition-colors">Cerrar ventana</button>
            </div>

            {# Formulario #}
            <form x-show="!isSuccess" x-transition.opacity class="space-y-5">
                
                <div x-show="serverError" x-cloak class="p-4 bg-red-50 text-red-600 text-sm font-medium rounded-xl border border-red-100" x-text="serverError"></div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-text-main ml-1">Nombre Completo</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-muted">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        </span>
                        <input type="text" x-model="formData.name" placeholder="Ej. Juan Pérez" required
                               class="w-full h-14 pl-12 pr-4 rounded-2xl bg-background-light border-transparent focus:bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-text-main">
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-text-main ml-1">Correo Electrónico</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-muted">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        </span>
                        <input type="email" x-model="formData.email" placeholder="juan@ejemplo.com" required
                               class="w-full h-14 pl-12 pr-4 rounded-2xl bg-background-light border-transparent focus:bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all text-text-main">
                    </div>
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-text-main ml-1">Teléfono</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2" :class="errors.phone ? 'text-red-500' : 'text-muted'">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        </span>
                        <input type="tel" x-model="formData.phone" @input="validatePhone" placeholder="+56 9 1234 5678" required
                               class="w-full h-14 pl-12 pr-10 rounded-2xl transition-all text-text-main"
                               :class="errors.phone ? 'bg-red-50 border-red-300 focus:ring-red-500/20 focus:border-red-500 text-red-900' : 'bg-background-light border-transparent focus:bg-white focus:border-primary focus:ring-2 focus:ring-primary/20'">
                        <span x-show="errors.phone" class="absolute right-4 top-1/2 -translate-y-1/2 text-red-500">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                        </span>
                    </div>
                    <p x-show="errors.phone" class="text-xs text-red-500 ml-1 mt-1">Por favor, ingresa un número válido.</p>
                </div>

                <div class="space-y-1.5" x-data="{ open: false }" @click.outside="open = false">
                    <label class="text-xs font-bold text-text-main ml-1">Cursos de Interés</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 z-10" :class="errors.course ? 'text-red-500' : 'text-muted'">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                        </span>
                        
                        <div @click="open = !open" tabindex="0" @keydown.enter="open = !open"
                             class="w-full min-h-[56px] pl-12 pr-10 py-2 rounded-2xl border transition-all cursor-pointer flex flex-wrap items-center gap-2"
                             :class="errors.course ? 'bg-red-50 border-red-300 ring-2 ring-red-500/20' : (open ? 'bg-white border-primary ring-2 ring-primary/20' : 'bg-background-light border-transparent')">
                             
                            <template x-if="formData.course.length === 0">
                                <span class="text-text-main select-none mt-0.5" :class="errors.course ? 'text-red-900' : 'text-muted'">Selecciona cursos...</span>
                            </template>
                            
                            <template x-for="val in formData.course" :key="val">
                                <span class="inline-flex items-center gap-1 bg-primary text-white text-xs font-bold px-2.5 py-1.5 rounded-lg z-10">
                                    <span x-text="getCourseLabel(val)"></span>
                                    <button type="button" @click.stop="formData.course = formData.course.filter(c => c !== val); if(formData.course.length === 0) errors.course = true;" class="hover:text-red-200 transition-colors focus:outline-none">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                                    </button>
                                </span>
                            </template>
                        </div>
                        
                        <span class="absolute right-4 top-1/2 -translate-y-1/2 text-muted pointer-events-none transition-transform duration-200"
                              :class="open ? 'rotate-180' : ''">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </span>
                        
                        <div x-show="open" 
                             x-transition:enter="transition ease-out duration-150"
                             x-transition:enter-start="opacity-0 -translate-y-2"
                             x-transition:enter-end="opacity-100 translate-y-0"
                             x-transition:leave="transition ease-in duration-100"
                             x-transition:leave-start="opacity-100 translate-y-0"
                             x-transition:leave-end="opacity-0 -translate-y-2"
                             class="absolute z-[100] top-[calc(100%+8px)] left-0 w-full bg-white rounded-2xl shadow-xl border border-gray-100 py-2"
                             x-cloak>
                            <template x-for="option in courseOptions" :key="option.value">
                                <label class="flex items-center gap-3 px-4 py-3 hover:bg-background-light cursor-pointer transition-colors group">
                                    <div class="relative flex items-center justify-center w-5 h-5 border-2 rounded transition-colors"
                                         :class="formData.course.includes(option.value) ? 'border-primary bg-primary' : 'border-gray-300 group-hover:border-primary'">
                                        <svg x-show="formData.course.includes(option.value)" class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                    </div>
                                    <input type="checkbox" :value="option.value" x-model="formData.course" @change="errors.course = formData.course.length === 0" class="sr-only">
                                    <span class="text-sm font-medium text-text-main" x-text="option.label"></span>
                                </label>
                            </template>
                        </div>
                    </div>
                    <p x-show="errors.course" class="text-xs text-red-500 ml-1 mt-1" x-cloak>Por favor, selecciona al menos un curso.</p>
                </div>

                <button type="submit" :disabled="isLoading || errors.phone || formData.course.length === 0" 
                        class="w-full h-14 mt-4 bg-primary text-white rounded-2xl font-bold font-display uppercase tracking-wide flex items-center justify-center gap-2 hover:brightness-110 shadow-lg shadow-primary/30 transition-all disabled:opacity-70 disabled:cursor-not-allowed group">
                    <span x-text="isLoading ? 'Enviando...' : 'Enviar mensaje'"></span>
                    <svg x-show="!isLoading" class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    <svg x-show="isLoading" x-cloak class="w-5 h-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                </button>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('contactForm', () => ({
        formData: {
            name: '',
            email: '',
            phone: '',
            course: []
        },
        courseOptions: [
            { value: 'Clase B', label: 'Licencia Clase B' },
            { value: 'Clase A2', label: 'Profesional A2' },
            { value: 'Clase A4', label: 'Profesional A4' }
        ],
        errors: { phone: false, course: false },
        isLoading: false,
        isSuccess: false,
        serverError: '',

        init() {
            window.addEventListener('preselect-course', (e) => {
                const requestedCourse = e.detail;
                if (!requestedCourse) return;

                const normalize = (str) => {
                    return String(str)
                        .toLowerCase()
                        .normalize("NFD")
                        .replace(/[\u0300-\u036f]/g, "")
                        .trim();
                };

                const normalizedRequested = normalize(requestedCourse);

                const option = this.courseOptions.find(opt => {
                    const normalizedVal = normalize(opt.value);
                    const normalizedLabel = normalize(opt.label);
                    
                    return normalizedRequested.includes(normalizedVal) || 
                           normalizedVal.includes(normalizedRequested) ||
                           normalizedRequested.includes(normalizedLabel) ||
                           normalizedLabel.includes(normalizedRequested);
                });

                if (option) {
                    this.formData.course = [option.value];
                    this.errors.course = false;
                }
            });
        },

        getCourseLabel(val) {
            const opt = this.courseOptions.find(o => o.value === val);
            return opt ? opt.label : val;
        },

        validatePhone() {
            const phoneRegex = /^[+]?[\d\s-]{8,15}$/;
            this.errors.phone = this.formData.phone !== '' && !phoneRegex.test(this.formData.phone);
        },

        async submitForm() {
            if (this.formData.course.length === 0) {
                this.errors.course = true;
            }
            if (this.errors.phone || this.errors.course) return;
            
            this.isLoading = true;
            this.serverError = '';

            try {
                const response = await fetch('/wp-json/abc/v1/contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.formData)
                });

                const result = await response.json();

                if (response.ok) {
                    this.isSuccess = true;
                } else {
                    this.serverError = result.message || 'Ocurrió un error al enviar el mensaje. Intenta nuevamente.';
                }
            } catch (error) {
                this.serverError = 'Error de conexión. Por favor, verifica tu internet.';
            } finally {
                this.isLoading = false;
            }
        },

        resetForm() {
            this.formData = { name: '', email: '', phone: '', course: [] };
            this.isSuccess = false;
            this.serverError = '';
            this.errors.phone = false;
            this.errors.course = false;
        }
    }))
})
</script>
</file>

<file path="templates/components/floating-buttons.twig">
<div x-data="floatingButtons()" x-init="init()" class="fixed bottom-0 right-0 z-50 pointer-events-none">

    {# ═══════════════════════════════════════════════════ #}
    {# 1. BOTÓN WHATSAPP                                   #}
    {# ═══════════════════════════════════════════════════ #}
    <div class="fixed bottom-6 right-5 md:right-6 flex flex-col items-end gap-3 pointer-events-auto z-50">

        {# Tooltip #}
        <div x-show="showTooltip && !tooltipDismissed"
             x-transition:enter="transition ease-out duration-500"
             x-transition:enter-start="opacity-0 translate-y-4 scale-95"
             x-transition:enter-end="opacity-100 translate-y-0 scale-100"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-start="opacity-100 scale-100"
             x-transition:leave-end="opacity-0 translate-y-2 scale-95"
             x-cloak
             class="relative bg-white rounded-2xl shadow-xl px-4 py-3 border border-gray-100 max-w-[200px] cursor-default"
             @click.stop>
            
            {# Flecha del tooltip #}
            <div class="absolute right-5 -bottom-2 w-4 h-4 bg-white border-r border-b border-gray-100 rotate-45"></div>
            
            <button @click="tooltipDismissed = true" 
                    class="absolute -top-2 -right-2 w-5 h-5 bg-gray-200 hover:bg-gray-300 rounded-full flex items-center justify-center transition-colors"
                    aria-label="Cerrar">
                <svg class="w-3 h-3 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            
            <p class="text-sm font-semibold text-text-main leading-snug">¿Necesitas ayuda? 👋</p>
            <p class="text-[0.8rem] text-muted mt-0.5">Escríbenos por WhatsApp</p>
        </div>

        {# Botón principal WhatsApp #}
        <a href="https://api.whatsapp.com/send?phone=56992199314&text=%C2%A1Hola!%20Necesito%20m%C3%A1s%20informaci%C3%B3n...."
           target="_blank"
           rel="noopener noreferrer"
           aria-label="Contactar por WhatsApp"
           class="group relative flex items-center justify-center w-[52px] h-[52px] md:w-[56px] md:h-[56px] rounded-full shadow-lg transition-all duration-300 hover:scale-110 hover:shadow-xl"
           style="background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);"
           @mouseenter="tooltipDismissed = true">
            
            {# Pulse ring #}
            <span class="absolute inset-0 rounded-full animate-ping opacity-20" style="background-color: #25D366;"></span>
            
            {# WhatsApp SVG icon #}
            <svg class="w-8 h-8 md:w-9 md:h-9 text-white relative z-10" viewBox="0 0 24 24" fill="currentColor">
