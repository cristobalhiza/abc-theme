           class="flex items-center justify-center gap-1.5 px-5 py-3 bg-white/95 backdrop-blur-md text-primary font-display font-bold text-[0.75rem] uppercase tracking-wider rounded-full shadow-lg shadow-primary/20 border border-primary/10 transition-transform active:scale-95 whitespace-nowrap ring-2 ring-transparent active:ring-primary/30">
