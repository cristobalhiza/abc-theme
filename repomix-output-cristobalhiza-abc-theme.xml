<file path="templates/components/sections/testimonials.twig">
{# Ubicación: templates/components/testimonials.twig #}

<section id="testimonios" class="py-16 bg-background-light overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
        
        <div class="text-center mb-16">
            <h2 class="text-primary font-black tracking-[0.3em] uppercase text-xs mb-3">Casos de Éxito</h2>
            <h2 class="text-4xl font-bold mb-4 tracking-tight font-display text-text-main">Lo que dicen nuestros alumnos</h2>
            <p class="text-muted text-base max-w-xl mx-auto font-medium">Cientos de conductores responsables confían en nuestra metodología para obtener su licencia.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
            {% for review in google_reviews %}
                <div class="bg-surface rounded-3xl p-8 shadow-float border border-gray-100 flex flex-col h-full transform transition-all duration-500 hover:-translate-y-2 hover:shadow-xl">
                    <div class="flex items-center justify-between mb-6">
                        <div class="flex items-center gap-4">
                            <img src="{{ review.profile_photo_url }}" alt="Avatar de {{ review.author_name }}" class="w-12 h-12 rounded-full object-cover">
                            <div>
                                <h4 class="font-bold text-text-main leading-tight">{{ review.author_name }}</h4>
                                <span class="text-xs text-muted">{{ review.relative_time_description }}</span>
                            </div>
                        </div>
                        <svg class="w-6 h-6" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                    </div>
                    
                    <div class="flex gap-1 mb-4 text-[#FBBC05]">
                        {% for i in 1..review.rating %}
                            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                        {% endfor %}
                    </div>

                    <p class="text-muted text-sm leading-relaxed flex-grow">"{{ review.text }}"</p>
                </div>
            {% endfor %}
        </div>

        {% if fotos_alumnos is not empty %}
            <div class="bg-surface rounded-[40px] p-8 md:p-12 shadow-float border border-gray-100 relative">
                <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-6">
                    <div>
                        <h3 class="text-3xl font-bold font-display text-text-main mb-2">Nuevos Conductores de <span class="text-primary">ABC Conducción</span></h3>
                        <p class="text-muted font-medium">Alumnos que ya superaron con éxito su examen municipal.</p>
                    </div>
                </div>

                <div x-data="{ 
                        activeIndex: 0,
                        total: {{ fotos_alumnos|length }},
                        autoScrollInterval: null,
                        init() {
                            this.startAutoScroll();
                            this.$refs.slider.addEventListener('scroll', () => {
                                if (!this.$refs.slider.children.length) return;
                                const item = this.$refs.slider.children[0];
                                const itemWidth = item.offsetWidth + 24; 
                                if (itemWidth > 0) {
                                    this.activeIndex = Math.round(this.$refs.slider.scrollLeft / itemWidth);
                                }
                            });
                        },
                        scrollNext() { 
                            const slider = this.$refs.slider;
                            if (slider.scrollLeft >= slider.scrollWidth - slider.clientWidth - 10) {
                                this.scrollTo(0);
                            } else {
                                let next = this.activeIndex + 1;
                                if (next >= this.total) next = 0;
                                this.scrollTo(next);
                            }
                        },
                        scrollPrev() { 
                            let prev = this.activeIndex - 1;
                            if (prev < 0) prev = this.total - 1;
                            this.scrollTo(prev);
                        },
                        scrollTo(index) {
                            if (index < 0 || index >= this.total) return;
                            const item = this.$refs.slider.children[index];
                            if (item) {
                                this.$refs.slider.scrollTo({ 
                                    left: item.offsetLeft - this.$refs.slider.children[0].offsetLeft, 
                                    behavior: 'smooth' 
                                });
                            }
                        },
                        startAutoScroll() {
                            this.autoScrollInterval = setInterval(() => {
                                this.scrollNext();
                            }, 3000);
                        },
                        stopAutoScroll() {
                            if (this.autoScrollInterval) clearInterval(this.autoScrollInterval);
                        }
                    }" 
                    @touchstart="stopAutoScroll"
                    @touchend="startAutoScroll"
                    class="group">
                    
                    <div class="relative">
                        <button @click="scrollPrev" class="absolute -left-5 top-1/2 -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-white text-primary shadow-lg flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:scale-110 hover:bg-primary hover:text-white" aria-label="Anterior">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                        </button>

                        <div x-ref="slider" class="flex gap-6 overflow-x-auto snap-x snap-mandatory hide-scrollbar pb-4 pt-4 -mx-4 px-4">
                            {% for foto_id in fotos_alumnos %}
                                {% set image = get_image(foto_id) %}
                                <div class="snap-center shrink-0 w-[280px] md:w-[320px]">
                                    <div class="rounded-3xl overflow-hidden shadow-md border-4 border-white aspect-[4/5] relative group/photo">
                                        <img src="{{ image.src }}" alt="Alumno aprobado" class="w-full h-full object-cover transition-transform duration-700 group-hover/photo:scale-110" loading="lazy">
                                        <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-transparent to-transparent opacity-0 group-hover/photo:opacity-100 transition-opacity duration-300"></div>
                                        <div class="absolute bottom-4 right-4 bg-white/90 backdrop-blur p-2 rounded-xl shadow-lg opacity-0 group-hover/photo:opacity-100 transition-all duration-300 translate-y-4 group-hover/photo:translate-y-0">
                                            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>

                        <button @click="scrollNext" class="absolute -right-5 top-1/2 -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-white text-primary shadow-lg flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity hover:scale-110 hover:bg-primary hover:text-white" aria-label="Siguiente">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        </button>
                    </div>

                    <!-- Paginación Dots -->
                    <div class="flex justify-center gap-2 mt-6 flex-wrap">
                        <template x-for="i in total" :key="i">
                            <button @click="scrollTo(i - 1)" 
                                class="transition-all duration-300 rounded-full"
                                :class="activeIndex === (i - 1) ? 'w-6 h-2 bg-primary' : 'w-2 h-2 bg-primary/30 hover:bg-primary/50'"
                                :aria-label="'Ir a imagen ' + i">
                            </button>
                        </template>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</section>

<style>
.hide-scrollbar::-webkit-scrollbar { display: none; }
.hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
</file>

