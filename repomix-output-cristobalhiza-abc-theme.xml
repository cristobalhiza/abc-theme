<section id="specialties" class="py-24 relative bg-background overflow-hidden">
    {# Elementos decorativos de fondo #}
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-accent/5 rounded-full blur-3xl translate-y-1/3 -translate-x-1/3 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        
        {# Cabecera de la Sección #}
        <div class="text-center max-w-3xl mx-auto mb-16" x-data="{ shown: false }" x-intersect.once="shown = true">
            <div class="inline-flex items-center gap-2 text-primary mb-4 transition-all duration-700 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
                <span class="h-1 w-12 bg-primary rounded-full"></span>
                <span class="text-sm font-bold uppercase tracking-widest">Nuestras Herramientas</span>
                <span class="h-1 w-12 bg-primary rounded-full"></span>
            </div>
            <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-text-main font-display mb-6 transition-all duration-700 delay-100 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
                Preparación Integral para tu <span class="text-primary">Éxito en Ruta</span>
            </h2>
            <p class="text-lg text-muted font-medium transition-all duration-700 delay-200 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
                Te entregamos todos los recursos necesarios para que obtengas tu licencia con confianza, seguridad y en el menor tiempo posible.
            </p>
        </div>

        {# Cuadrícula Bento (Bento Box Layout) #}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8" x-data="{ shown: false }" x-intersect.once.margin.-100px="shown = true">
            
            {# Tarjeta 1: Teoría (Alta) #}
            <div class="md:col-span-1 md:row-span-2 bg-white rounded-[32px] p-8 shadow-float border border-gray-50 flex flex-col justify-between transition-all duration-700 transform hover:-translate-y-2 hover:shadow-xl group"
                 :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
                <div>
                    <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-8 group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                        {{ specialties[0].icon|raw }}
                    </div>
                    <h3 class="text-2xl font-bold font-display text-text-main mb-4">{{ specialties[0].title }}</h3>
                    <p class="text-muted leading-relaxed">{{ specialties[0].desc }}</p>
                </div>
                
                {# Elemento visual integrado para la tarjeta grande #}
                <div class="mt-8 pt-8 border-t border-gray-100">
                    <div class="flex items-center gap-3 text-sm font-bold text-primary">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                        Incluye Ensayos Audiovisuales
                    </div>
                </div>
            </div>

            {# Tarjeta Destacada: Flota de Vehículos (Ancha) #}
            <div class="md:col-span-2 bg-primary rounded-[32px] p-8 lg:p-12 shadow-xl shadow-primary/20 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-8 transition-all duration-700 delay-100 transform hover:-translate-y-2 hover:shadow-2xl"
                 :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
                 
                {# Efecto de brillo de fondo #}
                <div class="absolute top-0 right-0 w-[300px] h-[300px] bg-white/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
                
                <div class="relative z-10 flex-1">
                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/20 rounded-full text-white text-xs font-bold uppercase tracking-wider mb-6">
                        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
                        Práctica Real
                    </div>
                    <h3 class="text-3xl lg:text-4xl font-bold font-display text-white mb-4 leading-tight">Flota de Vehículos Modernos</h3>
                    <p class="text-white/90 text-lg">Nuestros vehículos están equipados con tecnología de <strong class="text-white font-black">doble comando</strong>, garantizando tu seguridad y la del instructor en todo momento durante las clases prácticas.</p>
                </div>
                
                <div class="relative z-10 w-24 h-24 lg:w-32 lg:h-32 shrink-0 bg-white rounded-full flex items-center justify-center shadow-inner text-primary">
                    <svg class="w-12 h-12 lg:w-16 lg:h-16" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>
                </div>
            </div>

            {# Tarjeta 2: Psicotécnicos #}
            <div class="{{ specialties[1].bg }} rounded-[32px] p-8 shadow-float border border-gray-50 transition-all duration-700 delay-200 transform hover:-translate-y-2 hover:shadow-xl group"
                 :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
                <div class="w-14 h-14 rounded-2xl {{ specialties[1].iconBg }} {{ specialties[1].iconColor }} flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                    <div class="w-7 h-7">{{ specialties[1].icon|raw }}</div>
