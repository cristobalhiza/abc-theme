                <h3 class="text-xl font-bold font-display {{ specialties[1].text }} mb-3">{{ specialties[1].title }}</h3>
                <p class="text-muted leading-relaxed text-sm">{{ specialties[1].desc }}</p>
            </div>

            {# Tarjeta 3: Exámenes #}
            <div class="{{ specialties[2].bg }} rounded-[32px] p-8 shadow-float border border-gray-50 transition-all duration-700 delay-300 transform hover:-translate-y-2 hover:shadow-xl group"
                 :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
                <div class="w-14 h-14 rounded-2xl {{ specialties[2].iconBg }} {{ specialties[2].iconColor }} flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
                    <div class="w-7 h-7">{{ specialties[2].icon|raw }}</div>
                </div>
                <h3 class="text-xl font-bold font-display {{ specialties[2].text }} mb-3">{{ specialties[2].title }}</h3>
                <p class="text-muted leading-relaxed text-sm">{{ specialties[2].desc }}</p>
            </div>

        </div>
    </div>
</section>

