            <a href="{{ site.url }}/nuestra-escuela" class="bg-white p-6 md:p-8 flex flex-col items-center md:items-start text-center md:text-left rounded-[32px] border border-gray-100 shadow-float hover:border-primary/30 hover:shadow-xl transition-all duration-500 group">
                <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center mb-6 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <h3 class="font-display text-2xl font-bold mb-3">Nuestra Escuela</h3>
                <p class="font-body text-base text-muted">Descubre nuestro equipamiento e instalaciones.</p>
            </a>
            
            <a href="{{ site.url }}#contacto" class="bg-white p-6 md:p-8 flex flex-col items-center md:items-start text-center md:text-left rounded-[32px] border border-gray-100 shadow-float hover:border-primary/30 hover:shadow-xl transition-all duration-500 group">
                <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center mb-6 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
